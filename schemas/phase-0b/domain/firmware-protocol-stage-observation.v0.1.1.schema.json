  "x-ptah-schema-name":"domain.firmware-protocol-stage-observation",
  "x-ptah-schema-version":"0.1.1",
  "x-ptah-maturity":"candidate",
  "x-ptah-supersedes":"urn:ptah:schema:domain:firmware-protocol-stage-observation:0.1.0",
  "type":"object",
  "additionalProperties":false,
