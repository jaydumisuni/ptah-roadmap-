  "allOf":[
    {"if":{"properties":{"stage":{"const":"transport_authorized"}},"required":["stage"]},"then":{"properties":{"stage_result":{"enum":["acknowledged","verified","failed","timed_out","disconnected","inconclusive"]}}}},
    {"if":{"properties":{"stage":{"const":"cleanup_verified"}},"required":["stage"]},"then":{"properties":{"stage_result":{"enum":["verified","failed","inconclusive"]}}}}
  ]
