    "stage":{"type":"string","enum":["interface_detected","interface_claimed","transport_authorized","protocol_handshake","boot_or_download_mode_confirmed","first_stage_loaded","second_stage_or_programmer_loaded","service_configured","layout_inventoried","read_completed","backup_verified","write_acknowledged","write_read_back_verified","device_reset_observed","device_boot_observed","cleanup_verified","authoritative_external_result"]},
    "stage_result":{"type":"string","enum":["observed","acknowledged","verified","failed","timed_out","disconnected","unsupported","inconclusive"]},
    "backend_alias_refs":{"type":"array","items":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},"uniqueItems":true},
