{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:ptah:schema:domain:disk-image:0.1.0",
  "title": "Ptah Disk Image Identity",
  "x-ptah-schema-name": "domain.disk-image",
  "x-ptah-schema-version": "0.1.0",
  "x-ptah-maturity": "candidate",
  "type": "object",
  "additionalProperties": false,
  "required": ["envelope", "object_ref", "current_image_revision_ref", "image_revision_refs", "created_at", "extensions"],
  "properties": {
    "envelope": {
      "allOf": [
        {"$ref": "urn:ptah:schema:common:entity-envelope:0.1.0"},
        {"properties": {"entity_kind": {"const": "disk.image"}}}
      ]
    },
    "object_ref": {"$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},
    "current_image_revision_ref": {"$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},
    "image_revision_refs": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},
      "uniqueItems": true
    },
    "source_role": {
      "type": "string",
      "enum": ["uploaded_image", "device_read", "filesystem_export", "converted_image", "generated_image", "snapshot", "other_registered"]
    },
    "source_record_refs": {
      "type": "array",
      "items": {"$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},
      "uniqueItems": true
    },
    "replacement_ref": {"$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},
    "created_at": {"$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/utcDateTime"},
    "limitations": {"type": "array", "items": {"type": "string", "minLength": 1, "maxLength": 4096}},
    "extensions": {"$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/extensions"}
  }
}
