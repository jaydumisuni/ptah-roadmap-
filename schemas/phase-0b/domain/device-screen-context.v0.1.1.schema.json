{
  "$schema":"https://json-schema.org/draft/2020-12/schema",
  "$id":"urn:ptah:schema:domain:device-screen-context:0.1.1",
  "title":"Ptah Device Screen Context",
  "description":"Corrected partial visual/semantic observation bound to exact Stream, Interface, Connection epoch, Provider revision/generation and freshness.",
  "x-ptah-schema-name":"domain.device-screen-context",
  "x-ptah-schema-version":"0.1.1",
  "x-ptah-maturity":"candidate",
  "x-ptah-supersedes":"urn:ptah:schema:domain:device-screen-context:0.1.0",
  "type":"object",
  "additionalProperties":false,
  "required":["envelope","device_session_ref","device_ref","interface_ref","connection_ref","connection_epoch","provider_revision_ref","provider_instance_ref","provider_generation","stream_ref","display_or_surface_claim","captured_at","valid_until","screenshot_object_ref","coverage","privacy_policy_refs","extensions"],
  "properties":{
    "envelope":{"allOf":[{"$ref":"urn:ptah:schema:common:entity-envelope:0.1.0"},{"properties":{"entity_kind":{"const":"device.screen_context"}}}]},
    "device_session_ref":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},
    "device_ref":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},
    "interface_ref":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},
    "connection_ref":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},
    "connection_epoch":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/nonNegativeInteger"},
    "provider_revision_ref":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},
    "provider_instance_ref":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},
    "provider_generation":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/nonNegativeInteger"},
    "stream_ref":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},
    "display_or_surface_claim":{"type":"string","minLength":1,"maxLength":512},
    "geometry_or_orientation":{"type":"object","additionalProperties":{"type":["string","integer","number","boolean"]}},
    "captured_at":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/utcDateTime"},
    "valid_until":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/utcDateTime"},
    "screenshot_object_ref":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},
    "visible_text_or_semantic_refs":{"type":"array","items":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},"uniqueItems":true},
    "application_session_ref":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},
    "coverage":{"type":"string","enum":["full_observed_surface","partial","occluded","redacted","unavailable_semantics","unknown"]},
    "redaction_refs":{"type":"array","items":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},"uniqueItems":true},
    "privacy_policy_refs":{"type":"array","minItems":1,"items":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},"uniqueItems":true},
    "evidence_refs":{"type":"array","items":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},"uniqueItems":true},
    "limitations":{"type":"array","items":{"type":"string","minLength":1,"maxLength":4096}},
    "extensions":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/extensions"}
  }
