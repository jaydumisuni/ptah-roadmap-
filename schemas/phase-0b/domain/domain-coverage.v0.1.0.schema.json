{
  "$schema":"https://json-schema.org/draft/2020-12/schema",
  "$id":"urn:ptah:schema:domain:domain-coverage:0.1.0",
  "title":"Ptah Domain Operation Coverage",
  "x-ptah-schema-name":"domain.domain-coverage",
  "x-ptah-schema-version":"0.1.0",
  "x-ptah-maturity":"candidate",
  "type":"object","additionalProperties":false,
  "required":["envelope","operation_request_ref","operation_run_ref","subject_refs","requested_scope","processed_scope","coverage_state","budget_requested","budget_consumed","observed_at","extensions"],
  "properties":{
    "envelope":{"allOf":[{"$ref":"urn:ptah:schema:common:entity-envelope:0.1.0"},{"properties":{"entity_kind":{"const":"domain.coverage"}}}]},
    "operation_request_ref":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},
    "operation_run_ref":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},
    "subject_refs":{"type":"array","minItems":1,"items":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},"uniqueItems":true},
    "requested_scope":{"type":"array","minItems":1,"items":{"type":"string","minLength":1,"maxLength":2048},"uniqueItems":true},
    "processed_scope":{"type":"array","items":{"type":"string","minLength":1,"maxLength":2048},"uniqueItems":true},
    "skipped_scope":{"type":"array","items":{"type":"object","additionalProperties":false,"required":["scope","reason"],"properties":{"scope":{"type":"string","minLength":1,"maxLength":2048},"reason":{"type":"string","minLength":1,"maxLength":4096},"evidence_refs":{"type":"array","items":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},"uniqueItems":true}}}},
    "unknown_or_opaque_scope":{"type":"array","items":{"type":"object","additionalProperties":false,"required":["scope","state"],"properties":{"scope":{"type":"string","minLength":1,"maxLength":2048},"state":{"type":"string","enum":["unknown","opaque","encrypted","malformed","truncated","unsupported"]},"evidence_refs":{"type":"array","items":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},"uniqueItems":true}}}},
    "coverage_state":{"$ref":"urn:ptah:schema:domain:definitions:0.1.0#/$defs/coverageState"},
    "budget_requested":{"$ref":"urn:ptah:schema:domain:definitions:0.1.0#/$defs/budget"},
    "budget_consumed":{"$ref":"urn:ptah:schema:domain:definitions:0.1.0#/$defs/budget"},
    "child_object_count":{"type":"integer","minimum":0},
    "view_count":{"type":"integer","minimum":0},
    "relationship_count":{"type":"integer","minimum":0},
    "error_refs":{"type":"array","items":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},"uniqueItems":true},
    "observed_at":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/utcDateTime"},
    "limitations":{"type":"array","items":{"type":"string","minLength":1,"maxLength":4096}},
    "extensions":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/extensions"}
  }
}