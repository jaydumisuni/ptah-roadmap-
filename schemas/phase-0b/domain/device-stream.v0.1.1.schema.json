{
  "$schema":"https://json-schema.org/draft/2020-12/schema",
  "$id":"urn:ptah:schema:domain:device-stream:0.1.1",
  "title":"Ptah Device Stream",
  "description":"Corrected Device Stream binding exact Interface, Connection epoch and Provider revision/generation.",
  "x-ptah-schema-name":"domain.device-stream",
  "x-ptah-schema-version":"0.1.1",
  "x-ptah-maturity":"candidate",
  "x-ptah-supersedes":"urn:ptah:schema:domain:device-stream:0.1.0",
  "type":"object",
  "additionalProperties":false,
  "required":["envelope","lifecycle","device_session_ref","device_ref","stream_type","interface_ref","connection_ref","connection_epoch","provider_revision_ref","provider_instance_ref","provider_generation","format","privacy_policy_refs","started_at","extensions"],
  "properties":{
    "envelope":{"allOf":[{"$ref":"urn:ptah:schema:common:entity-envelope:0.1.0"},{"properties":{"entity_kind":{"const":"device.stream"}}}]},
    "lifecycle":{"$ref":"urn:ptah:schema:domain:definitions:0.1.0#/$defs/stateProjection"},
    "device_session_ref":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},
    "device_ref":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},
    "stream_type":{"type":"string","enum":["video","audio","control","clipboard","log","shell","file_transfer","semantic_context","other_registered"]},
    "interface_ref":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},
    "connection_ref":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},
    "connection_epoch":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/nonNegativeInteger"},
    "provider_revision_ref":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},
    "provider_instance_ref":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},
    "provider_generation":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/nonNegativeInteger"},
    "provider_capability_snapshot_ref":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},
    "format":{"type":"object","additionalProperties":{"type":["string","integer","number","boolean"]}},
    "geometry_or_orientation":{"type":"object","additionalProperties":{"type":["string","integer","number","boolean"]}},
    "display_or_channel_claim":{"type":"string","maxLength":512},
    "privacy_policy_refs":{"type":"array","minItems":1,"items":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},"uniqueItems":true},
    "recording_artifact_refs":{"type":"array","items":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},"uniqueItems":true},
    "started_at":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/utcDateTime"},
    "ended_at":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/utcDateTime"},
    "observation_refs":{"type":"array","items":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},"uniqueItems":true},
    "limitations":{"type":"array","items":{"type":"string","minLength":1,"maxLength":4096}},
    "extensions":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/extensions"}
  }
}
