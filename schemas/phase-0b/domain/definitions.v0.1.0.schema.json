{
  "$schema":"https://json-schema.org/draft/2020-12/schema",
  "$id":"urn:ptah:schema:domain:definitions:0.1.0",
  "title":"Ptah Domain, Firmware, Disk and Device Definitions",
  "x-ptah-schema-name":"domain.definitions",
  "x-ptah-schema-version":"0.1.0",
  "x-ptah-maturity":"candidate",
  "$defs":{
    "stateProjection":{"type":"object","additionalProperties":false,"required":["machine","machine_version","state","transition_sequence","changed_at","changed_by_ref"],"properties":{"machine":{"type":"string","pattern":"^[a-z][a-z0-9_.-]{2,127}$"},"machine_version":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/semver"},"state":{"type":"string","pattern":"^[a-z][a-z0-9_]{1,63}$"},"transition_sequence":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/nonNegativeInteger"},"changed_at":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/utcDateTime"},"changed_by_ref":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},"receipt_refs":{"type":"array","items":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},"uniqueItems":true}}},
    "domainOperationType":{"type":"string","enum":["detect","inventory","decompose","preview","open_or_mount","transform","compare","rebuild","validate","execute_or_run"]},
    "mutationClass":{"type":"string","enum":["none_read_only","copy_only","workspace_object_mutation","filesystem_write_overlay","device_read","device_backup","device_write","device_erase","device_repartition","device_reset_or_reboot","device_security_state","device_protected_nv","device_payload_execute","other_registered"]},
    "packCompatibilityDecision":{"type":"string","enum":["compatible","compatible_with_conditions","compatible_for_partial_scope","incompatible","unsupported_operation","unsupported_input","missing_dependency","missing_credential","resource_or_policy_blocked","unknown","stale"]},
    "coverageState":{"type":"string","enum":["complete_for_requested_scope","partial","budget_exhausted","credential_blocked","encrypted_locked","malformed_or_truncated","parser_failed","unsupported","opaque","unknown"]},
    "domainRunOutcome":{"type":"string","enum":["completed","completed_partial","failed","cancelled","blocked","uncertain"]},
    "firmwareCompatibilityDecision":{"type":"string","enum":["compatible_for_static_analysis","compatible_for_read","compatible_for_rebuild_copy","compatible_for_write","incompatible","ambiguous","missing_source_image","missing_loader_or_programmer","missing_key_or_credential","layout_mismatch","security_or_rollback_blocked","unsupported_backend_capability","stale"]},
    "protocolStage":{"type":"string","enum":["interface_detected","interface_claimed","protocol_handshake","boot_or_download_mode_confirmed","first_stage_loaded","second_stage_or_programmer_loaded","service_configured","layout_inventoried","read_completed","backup_verified","write_acknowledged","write_read_back_verified","device_reset_observed","device_boot_observed","authoritative_external_result"]},
    "deviceKind":{"type":"string","enum":["physical_android","android_emulator","physical_ios","ios_simulator","linux_host","windows_host","macos_host","virtual_machine","remote_application_provider","other_registered"]},
    "interfaceTransport":{"type":"string","enum":["adb_usb","adb_tcp","adb_tls","fastboot_usb","fastboot_tcp","mtp","usb_serial","usb_vendor","network_vendor","appium_proxy","accessibility_service","scrcpy_server","provider_native","other_registered"]},
    "sessionAvailability":{"type":"string","enum":["full","partial","observation_only","control_only","recovering","unavailable","unknown"]},
    "verificationDecision":{"type":"string","enum":["verified","verified_with_limitations","acknowledged_not_verified","mismatch","failed","inconclusive","blocked","unknown"]},
    "byteRange":{"type":"object","additionalProperties":false,"required":["offset","length"],"properties":{"offset":{"type":"integer","minimum":0},"length":{"type":"integer","minimum":0},"address_space":{"type":"string","enum":["file_bytes","expanded_logical_bytes","disk_lba","disk_bytes","partition_bytes","device_lun_bytes","memory_address","other_registered"]},"sector_size":{"type":"integer","minimum":1},"label":{"type":"string","maxLength":512}}},
    "budget":{"type":"object","additionalProperties":false,"properties":{"max_input_bytes":{"type":"integer","minimum":0},"max_runtime_seconds":{"type":"integer","minimum":0},"max_cpu_millis":{"type":"integer","minimum":0},"max_memory_bytes":{"type":"integer","minimum":0},"max_temporary_disk_bytes":{"type":"integer","minimum":0},"max_output_bytes":{"type":"integer","minimum":0},"max_child_objects":{"type":"integer","minimum":0},"max_recursion_depth":{"type":"integer","minimum":0},"max_expansion_ratio":{"type":"number","minimum":0},"registered_limits":{"type":"object","additionalProperties":{"type":["integer","number","string","boolean"]}}}},
    "requirementResult":{"type":"object","additionalProperties":false,"required":["requirement_key","result","evidence_refs"],"properties":{"requirement_key":{"type":"string","pattern":"^[a-z][a-z0-9_.-]{2,127}$"},"result":{"type":"string","enum":["satisfied","satisfied_with_conditions","unsatisfied","unsupported","unknown","stale"]},"evidence_refs":{"type":"array","items":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},"uniqueItems":true},"condition_refs":{"type":"array","items":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},"uniqueItems":true},"reason":{"type":"string","minLength":1,"maxLength":4096}}}
  }
}