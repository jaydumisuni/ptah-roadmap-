{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:ptah:schema:domain:device-operation-recovery:0.1.1",
  "title": "Ptah Device Operation Recovery",
  "x-ptah-schema-name": "domain.device-operation-recovery",
  "x-ptah-schema-version": "0.1.1",
  "x-ptah-maturity": "candidate",
  "type": "object",
  "additionalProperties": false,
  "required": ["envelope", "lifecycle", "firmware_operation_ref", "device_ref", "previous_session_ref", "previous_connection_ref", "previous_connection_epoch", "recovery_activity_ref", "recovery_operation_refs", "recovery_attempt_refs", "reconciliation_results", "decision", "started_at", "evidence_refs", "receipt_refs", "extensions"],
  "properties": {
    "envelope": {
      "allOf": [
        {"$ref": "urn:ptah:schema:common:entity-envelope:0.1.0"},
        {"properties": {"entity_kind": {"const": "device.operation_recovery"}}}
      ]
    },
    "lifecycle": {"$ref": "urn:ptah:schema:domain:definitions:0.1.0#/$defs/stateProjection"},
    "firmware_operation_ref": {"$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},
    "device_protocol_operation_ref": {"$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},
    "device_ref": {"$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},
    "previous_session_ref": {"$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},
    "previous_connection_ref": {"$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},
    "previous_connection_epoch": {"$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/nonNegativeInteger"},
    "previous_provider_generation": {"$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/nonNegativeInteger"},
    "new_session_ref": {"$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},
    "new_connection_ref": {"$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},
    "new_connection_epoch": {"$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/nonNegativeInteger"},
    "new_provider_generation": {"$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/nonNegativeInteger"},
    "recovery_activity_ref": {"$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},
    "recovery_operation_refs": {"type": "array", "minItems": 1, "items": {"$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"}, "uniqueItems": true},
    "recovery_attempt_refs": {"type": "array", "minItems": 1, "items": {"$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"}, "uniqueItems": true},
    "reconciliation_results": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["question", "result", "evidence_refs"],
        "properties": {
          "question": {"type": "string", "enum": ["operation_effect_occurred", "target_state_matches_expected", "backup_restorable", "safe_to_retry", "manual_intervention_required", "cleanup_completed", "other_registered"]},
          "result": {"type": "string", "enum": ["yes", "no", "partial", "unknown", "inconclusive", "blocked"]},
          "evidence_refs": {"type": "array", "minItems": 1, "items": {"$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"}, "uniqueItems": true},
          "details": {"type": "string", "maxLength": 4096}
        }
      }
    },
    "decision": {"type": "string", "enum": ["recovered_verified", "recovered_with_limitations", "safe_to_resume", "safe_to_retry_new_attempt", "manual_intervention_required", "unrecoverable", "inconclusive", "blocked"]},
    "started_at": {"$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/utcDateTime"},
    "completed_at": {"$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/utcDateTime"},
    "evidence_refs": {"type": "array", "minItems": 1, "items": {"$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"}, "uniqueItems": true},
    "receipt_refs": {"type": "array", "minItems": 1, "items": {"$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"}, "uniqueItems": true},
    "limitations": {"type": "array", "items": {"type": "string", "minLength": 1, "maxLength": 4096}},
    "extensions": {"$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/extensions"}
  }
}
