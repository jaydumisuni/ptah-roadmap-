{
  "$schema":"https://json-schema.org/draft/2020-12/schema",
  "$id":"urn:ptah:schema:domain:filesystem:0.1.0",
  "title":"Ptah Filesystem Identity",
  "x-ptah-schema-name":"domain.filesystem","x-ptah-schema-version":"0.1.0","x-ptah-maturity":"candidate",
  "type":"object","additionalProperties":false,
