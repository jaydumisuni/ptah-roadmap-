{
  "$schema":"https://json-schema.org/draft/2020-12/schema",
  "$id":"urn:ptah:schema:domain:domain-classification-decision:0.1.0",
  "title":"Ptah Domain Classification Decision",
  "x-ptah-schema-name":"domain.domain-classification-decision",
  "x-ptah-schema-version":"0.1.0",
  "x-ptah-maturity":"candidate",
  "type":"object","additionalProperties":false,
  "required":["envelope","subject_revision_ref","selected_routes","observation_refs","decision_status","decided_by_ref","policy_refs","evidence_refs","decided_at","extensions"],
  "properties":{
    "envelope":{"allOf":[{"$ref":"urn:ptah:schema:common:entity-envelope:0.1.0"},{"properties":{"entity_kind":{"const":"domain.classification_decision"}}}]},
    "subject_revision_ref":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},
    "selected_routes":{"type":"array","minItems":1,"items":{"type":"object","additionalProperties":false,"required":["claimed_type","pack_revision_ref","priority"],"properties":{"claimed_type":{"type":"string","pattern":"^[a-z][a-z0-9_.-]{2,127}$"},"claimed_subtype":{"type":"string","pattern":"^[a-z][a-z0-9_.-]{1,127}$"},"pack_revision_ref":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},"priority":{"type":"integer","minimum":0},"scope_or_condition_refs":{"type":"array","items":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},"uniqueItems":true}}}},
    "observation_refs":{"type":"array","minItems":1,"items":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},"uniqueItems":true},
    "conflicting_observation_refs":{"type":"array","items":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},"uniqueItems":true},
    "decision_status":{"type":"string","enum":["selected","selected_multiple_polyglot","ambiguous","unknown","encrypted","malformed","truncated","unsupported","opaque"]},
    "decided_by_ref":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},
    "policy_refs":{"type":"array","minItems":1,"items":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},"uniqueItems":true},
    "evidence_refs":{"type":"array","minItems":1,"items":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},"uniqueItems":true},
    "supersedes_decision_ref":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},
    "decided_at":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/utcDateTime"},
    "valid_until":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/utcDateTime"},
    "reason":{"type":"string","minLength":1,"maxLength":4096},
    "limitations":{"type":"array","items":{"type":"string","minLength":1,"maxLength":4096}},
    "extensions":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/extensions"}
  }
}