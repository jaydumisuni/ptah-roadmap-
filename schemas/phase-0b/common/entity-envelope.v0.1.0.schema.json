{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:ptah:schema:common:entity-envelope:0.1.0",
  "title": "Ptah Common Entity Envelope",
  "description": "Candidate common metadata envelope for canonical Ptah entity records.",
  "x-ptah-schema-name": "common.entity-envelope",
  "x-ptah-schema-version": "0.1.0",
  "x-ptah-maturity": "candidate",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "entity_id",
    "entity_kind",
    "schema_id",
    "schema_version",
    "record_revision",
    "created_at",
    "updated_at",
    "authority_ref",
    "privacy_class",
    "audience",
    "redaction_policy",
    "retention_policy",
    "extensions"
  ],
  "properties": {
    "entity_id": {
      "$ref": "definitions.v0.1.0.schema.json#/$defs/uuidv7"
    },
    "entity_kind": {
      "$ref": "definitions.v0.1.0.schema.json#/$defs/entityKind"
    },
    "schema_id": {
      "$ref": "definitions.v0.1.0.schema.json#/$defs/schemaId"
    },
    "schema_version": {
      "$ref": "definitions.v0.1.0.schema.json#/$defs/semver"
    },
    "record_revision": {
      "$ref": "definitions.v0.1.0.schema.json#/$defs/positiveInteger"
    },
    "created_at": {
      "$ref": "definitions.v0.1.0.schema.json#/$defs/utcDateTime"
    },
    "updated_at": {
      "$ref": "definitions.v0.1.0.schema.json#/$defs/utcDateTime"
    },
    "workspace_ref": {
      "$ref": "definitions.v0.1.0.schema.json#/$defs/entityRef"
    },
    "global_scope": {
      "type": "string",
      "enum": [
        "ptah_global",
        "organization_global",
        "public_global"
      ]
    },
    "authority_ref": {
      "$ref": "definitions.v0.1.0.schema.json#/$defs/entityRef"
    },
    "privacy_class": {
      "$ref": "definitions.v0.1.0.schema.json#/$defs/privacyClass"
    },
    "audience": {
      "$ref": "definitions.v0.1.0.schema.json#/$defs/audience"
    },
    "named_recipient_refs": {
      "type": "array",
      "items": {
        "$ref": "definitions.v0.1.0.schema.json#/$defs/entityRef"
      },
      "uniqueItems": true
    },
    "redaction_policy": {
      "$ref": "definitions.v0.1.0.schema.json#/$defs/redactionAction"
    },
    "retention_policy": {
      "$ref": "definitions.v0.1.0.schema.json#/$defs/retentionPolicy"
    },
    "supersedes_ref": {
      "$ref": "definitions.v0.1.0.schema.json#/$defs/entityRef"
    },
    "migrated_from_ref": {
      "$ref": "definitions.v0.1.0.schema.json#/$defs/entityRef"
    },
    "tombstone": {
      "oneOf": [
        {
          "$ref": "definitions.v0.1.0.schema.json#/$defs/tombstone"
        },
        {
          "type": "null"
        }
      ]
    },
    "extensions": {
      "$ref": "definitions.v0.1.0.schema.json#/$defs/extensions"
    }
  },
  "allOf": [
    {
      "oneOf": [
        {
          "required": [
            "workspace_ref"
          ],
          "not": {
            "required": [
              "global_scope"
            ]
          }
        },
        {
          "required": [
            "global_scope"
          ],
          "not": {
            "required": [
              "workspace_ref"
            ]
          }
        }
      ]
    },
    {
      "if": {
        "properties": {
          "audience": {
            "const": "named_recipients"
          }
        },
        "required": [
          "audience"
        ]
      },
      "then": {
        "required": [
          "named_recipient_refs"
        ],
        "properties": {
          "named_recipient_refs": {
            "minItems": 1
          }
        }
      },
      "else": {
        "not": {
          "required": [
            "named_recipient_refs"
          ]
        }
      }
    }
  ]
}
