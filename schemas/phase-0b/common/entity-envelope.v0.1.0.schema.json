{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:ptah:schema:common:entity-envelope:0.1.0",
  "title": "Ptah Common Entity Envelope",
  "description": "Candidate common metadata envelope for canonical Ptah entity records.",
  "x-ptah-schema-name": "common.entity-envelope",
  "x-ptah-schema-version": "0.1.0",
  "x-ptah-maturity": "candidate",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "entity_id",
    "entity_kind",
    "schema_id",
    "schema_version",
    "record_revision",
    "created_at",
    "updated_at",
    "authority_ref",
    "privacy_class",
    "audience",
    "redaction_policy",
    "retention_policy",
    "extensions"
  ],
  "properties": {
    "entity_id": { "$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/uuidv7" },
    "entity_kind": { "$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityKind" },
    "schema_id": { "$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/schemaId" },
    "schema_version": { "$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/semver" },
    "record_revision": { "$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/positiveInteger" },
    "created_at": { "$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/utcDateTime" },
    "updated_at": { "$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/utcDateTime" },
    "workspace_ref": { "$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef" },
    "global_scope": {
      "type": "string",
      "enum": ["ptah_global", "organization_global", "public_global"]
    },
    "authority_ref": { "$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef" },
    "privacy_class": { "$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/privacyClass" },
    "audience": { "$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/audience" },
    "named_recipient_refs": {
      "type": "array",
      "items": { "$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef" },
      "uniqueItems": true
    },
    "redaction_policy": { "$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/redactionAction" },
    "retention_policy": { "$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/retentionPolicy" },
    "supersedes_ref": { "$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef" },
    "migrated_from_ref": { "$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef" },
    "tombstone": {
      "oneOf": [
        { "$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/tombstone" },
        { "type": "null" }
      ]
    },
    "extensions": { "$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/extensions" }
  },
  "allOf": [
    {
      "oneOf": [
        {
          "required": ["workspace_ref"],
          "not": { "required": ["global_scope"] }
        },
        {
          "required": ["global_scope"],
          "not": { "required": ["workspace_ref"] }
        }
      ]
    },
    {
      "if": {
        "properties": { "audience": { "const": "named_recipients" } },
        "required": ["audience"]
      },
      "then": {
        "required": ["named_recipient_refs"],
        "properties": { "named_recipient_refs": { "minItems": 1 } }
      },
      "else": {
        "not": { "required": ["named_recipient_refs"] }
      }
    }
  ]
}
