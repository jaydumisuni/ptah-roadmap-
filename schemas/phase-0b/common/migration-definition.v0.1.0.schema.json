{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:ptah:schema:common:migration-definition:0.1.0",
  "title": "Ptah Migration Definition",
  "description": "Candidate versioned definition for deterministic or bounded schema/data migration.",
  "x-ptah-schema-name": "common.migration-definition",
  "x-ptah-schema-version": "0.1.0",
  "x-ptah-maturity": "candidate",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "migration_id",
    "migration_version",
    "source_schemas",
    "target_schema_id",
    "target_schema_version",
    "transform_tool",
    "loss_policy",
    "idempotency_policy",
    "rollback_policy",
    "extensions"
  ],
  "properties": {
    "migration_id": { "$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/uuidv7" },
    "migration_version": { "$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/semver" },
    "source_schemas": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["schema_id", "version_constraint"],
        "properties": {
          "schema_id": { "type": "string", "pattern": "^urn:ptah:schema:[a-z][a-z0-9_-]*(?::[a-z][a-z0-9_-]*)+:[0-9A-Za-z.+-]+$" },
          "version_constraint": { "type": "string", "minLength": 1, "maxLength": 256 }
        }
      }
    },
    "target_schema_id": { "$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/schemaId" },
    "target_schema_version": { "$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/semver" },
    "transform_tool": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tool_ref", "tool_version", "tool_digest"],
      "properties": {
        "tool_ref": { "$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef" },
        "tool_version": { "type": "string", "minLength": 1, "maxLength": 256 },
        "tool_digest": { "type": "string", "pattern": "^[a-z0-9][a-z0-9_-]*:[0-9a-f]+$" }
      }
    },
    "preconditions": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "loss_policy": {
      "type": "string",
      "enum": ["no_loss_allowed", "loss_allowed_with_report", "manual_review_for_loss", "unsupported_if_loss"]
    },
    "idempotency_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["idempotent", "deduplication_key_fields"],
      "properties": {
        "idempotent": { "type": "boolean" },
        "deduplication_key_fields": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "pattern": "^(?:/(?:[^~/]|~0|~1)*)*$" }
        }
      }
    },
    "rollback_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rollback_class"],
      "properties": {
        "rollback_class": {
          "type": "string",
          "enum": ["reverse_migration", "source_preserved_only", "manual_restore", "irreversible"]
        },
        "reverse_migration_ref": { "$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef" },
        "notes": { "type": "string", "maxLength": 4096 }
      },
      "allOf": [
        {
          "if": { "properties": { "rollback_class": { "const": "reverse_migration" } }, "required": ["rollback_class"] },
          "then": { "required": ["reverse_migration_ref"] }
        }
      ]
    },
    "field_mapping_specification_ref": { "$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef" },
    "compatibility_record_refs": {
      "type": "array",
      "items": { "$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef" },
      "uniqueItems": true
    },
    "extensions": { "$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/extensions" }
  }
}
