{
  "$schema":"https://json-schema.org/draft/2020-12/schema",
  "$id":"urn:ptah:schema:application:browser-binary-revision:0.1.0",
  "title":"Ptah Browser Binary Revision",
  "x-ptah-schema-name":"application.browser-binary-revision","x-ptah-schema-version":"0.1.0","x-ptah-maturity":"candidate",
  "type":"object","additionalProperties":false,
