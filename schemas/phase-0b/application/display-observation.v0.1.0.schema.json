{
  "$schema":"https://json-schema.org/draft/2020-12/schema",
  "$id":"urn:ptah:schema:application:display-observation:0.1.0",
  "title":"Ptah Application Display Observation",
  "x-ptah-schema-name":"application.display-observation","x-ptah-schema-version":"0.1.0","x-ptah-maturity":"candidate",
  "type":"object","additionalProperties":false,
  "required":["envelope","display_session_ref","application_session_ref","provider_generation","availability","observed_at","valid_until","evidence_refs","extensions"],
  "properties":{
