  "allOf":[
    {"if":{"properties":{"locality":{"const":"node_local"}}},"then":{"required":["node_ref","node_generation","node_capability_snapshot_ref","node_resource_snapshot_ref"],"not":{"required":["remote_service_ref"]}},"else":{"required":["remote_service_ref","provider_capability_snapshot_ref"],"not":{"anyOf":[{"required":["node_ref"]},{"required":["node_generation"]}]}}},
