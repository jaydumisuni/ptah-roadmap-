{
  "$schema":"https://json-schema.org/draft/2020-12/schema",
  "$id":"urn:ptah:schema:application:application-window-observation:0.1.0",
  "title":"Ptah Application Window Observation",
  "x-ptah-schema-name":"application.application-window-observation","x-ptah-schema-version":"0.1.0","x-ptah-maturity":"candidate",
  "type":"object","additionalProperties":false,
