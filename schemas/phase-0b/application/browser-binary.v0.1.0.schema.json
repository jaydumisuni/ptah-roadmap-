{
  "$schema":"https://json-schema.org/draft/2020-12/schema",
  "$id":"urn:ptah:schema:application:browser-binary:0.1.0",
  "title":"Ptah Browser Binary",
  "x-ptah-schema-name":"application.browser-binary","x-ptah-schema-version":"0.1.0","x-ptah-maturity":"candidate",
  "type":"object","additionalProperties":false,
  "required":["envelope","lifecycle","browser_key","name","current_revision_ref","revision_refs","created_at","extensions"],
  "properties":{
    "envelope":{"allOf":[{"$ref":"urn:ptah:schema:common:entity-envelope:0.1.0"},{"properties":{"entity_kind":{"const":"browser.binary"}}}]},
    "lifecycle":{"$ref":"urn:ptah:schema:application:definitions:0.1.0#/$defs/stateProjection"},
    "browser_key":{"type":"string","pattern":"^[a-z][a-z0-9_.-]{2,127}$"},
    "name":{"type":"string","minLength":1,"maxLength":256},
    "current_revision_ref":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},
    "revision_refs":{"type":"array","minItems":1,"items":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},"uniqueItems":true},
    "replacement_ref":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},
    "created_at":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/utcDateTime"},
    "limitations":{"type":"array","items":{"type":"string","minLength":1,"maxLength":4096}},
    "extensions":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/extensions"}
  }
}