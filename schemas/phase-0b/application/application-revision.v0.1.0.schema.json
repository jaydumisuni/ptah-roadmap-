{
  "$schema":"https://json-schema.org/draft/2020-12/schema",
  "$id":"urn:ptah:schema:application:application-revision:0.1.0",
  "title":"Ptah Application Revision",
  "x-ptah-schema-name":"application.application-revision","x-ptah-schema-version":"0.1.0","x-ptah-maturity":"candidate",
  "type":"object","additionalProperties":false,
  "required":["envelope","application_ref","revision_number","source_or_package_object_refs","content_digest_refs","version_claims","platform_and_architecture_claims","dependency_refs","capability_claim_refs","provenance_refs","created_at","extensions"],
  "properties":{
    "envelope":{"allOf":[{"$ref":"urn:ptah:schema:common:entity-envelope:0.1.0"},{"properties":{"entity_kind":{"const":"application.revision"}}}]},
    "application_ref":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},
    "revision_number":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/positiveInteger"},
    "parent_revision_refs":{"type":"array","items":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},"uniqueItems":true},
    "source_or_package_object_refs":{"type":"array","minItems":1,"items":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},"uniqueItems":true},
    "content_digest_refs":{"type":"array","minItems":1,"items":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},"uniqueItems":true},
    "version_claims":{"type":"object","additionalProperties":{"type":["string","number","boolean"]}},
    "platform_and_architecture_claims":{"type":"array","minItems":1,"items":{"type":"string","maxLength":256},"uniqueItems":true},
    "entrypoint_claims":{"type":"array","items":{"type":"string","maxLength":2048},"uniqueItems":true},
    "dependency_refs":{"type":"array","items":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},"uniqueItems":true},
    "capability_claim_refs":{"type":"array","items":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},"uniqueItems":true},
    "signature_or_verification_refs":{"type":"array","items":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},"uniqueItems":true},
    "privacy_and_security_requirement_refs":{"type":"array","items":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},"uniqueItems":true},
    "provenance_refs":{"type":"array","minItems":1,"items":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},"uniqueItems":true},
    "created_at":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/utcDateTime"},
    "limitations":{"type":"array","items":{"type":"string","minLength":1,"maxLength":4096}},
    "extensions":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/extensions"}
  }
}