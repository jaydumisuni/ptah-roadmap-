{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:ptah:schema:object:classification-decision:0.1.0",
  "title": "Ptah Classification Decision",
  "description": "Immutable routing/type-selection decision over retained detector observations for one purpose and policy revision.",
  "x-ptah-schema-name": "object.classification-decision",
  "x-ptah-schema-version": "0.1.0",
  "x-ptah-maturity": "candidate",
  "type": "object",
  "additionalProperties": false,
  "required": ["envelope", "decision_contract_version", "revision_ref", "purpose", "considered_observation_refs", "outcome", "selected_type", "selected_route", "policy_ref", "authority_ref", "reason", "limitations", "extensions"],
  "properties": {
    "envelope": {
      "allOf": [
        { "$ref": "urn:ptah:schema:common:entity-envelope:0.1.0" },
        { "properties": { "entity_kind": { "const": "object.classification_decision" } } }
      ]
    },
    "decision_contract_version": { "$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/semver" },
    "revision_ref": { "$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef" },
    "purpose": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
    "considered_observation_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef" },
      "uniqueItems": true
    },
    "outcome": { "$ref": "urn:ptah:schema:object:definitions:0.1.0#/$defs/classificationOutcome" },
    "selected_type": {
      "oneOf": [
        { "type": "string", "minLength": 1, "maxLength": 512 },
        { "type": "null" }
      ]
    },
    "selected_route": {
      "oneOf": [
        { "type": "string", "minLength": 1, "maxLength": 512 },
        { "type": "null" }
      ]
    },
    "policy_ref": { "$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef" },
    "authority_ref": { "$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef" },
    "reason": { "type": "string", "minLength": 1, "maxLength": 8192 },
    "expires_at": { "$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/utcDateTime" },
    "reevaluation_triggers": { "$ref": "urn:ptah:schema:object:definitions:0.1.0#/$defs/stringList" },
    "supersedes_decision_ref": { "$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef" },
    "limitations": { "$ref": "urn:ptah:schema:object:definitions:0.1.0#/$defs/stringList" },
    "extensions": { "$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/extensions" }
  },
  "allOf": [
    {
      "if": { "properties": { "outcome": { "const": "selected" } }, "required": ["outcome"] },
      "then": {
        "properties": {
          "selected_type": { "type": "string", "minLength": 1 },
          "selected_route": { "type": "string", "minLength": 1 }
        }
      }
    }
  ]
}