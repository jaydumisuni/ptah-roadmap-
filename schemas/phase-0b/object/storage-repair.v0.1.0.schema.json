{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:ptah:schema:storage:repair:0.1.0",
  "title": "Ptah Storage Repair",
  "description": "Immutable repair/copy/reconstruction record from verified source Location(s) to a target Location.",
  "x-ptah-schema-name": "storage.repair",
  "x-ptah-schema-version": "0.1.0",
  "x-ptah-maturity": "candidate",
  "type": "object",
  "additionalProperties": false,
  "required": ["envelope", "repair_contract_version", "content_ref", "source_location_refs", "target_location_ref", "repair_kind", "production_correlation", "pre_repair_verification_refs", "post_repair_verification_refs", "outcome", "receipt_refs", "limitations", "extensions"],
  "properties": {
    "envelope": {
      "allOf": [
        { "$ref": "urn:ptah:schema:common:entity-envelope:0.1.0" },
        { "properties": { "entity_kind": { "const": "storage.repair" } } }
      ]
    },
    "repair_contract_version": { "$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/semver" },
    "content_ref": { "$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef" },
    "source_location_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef" },
      "uniqueItems": true
    },
    "target_location_ref": { "$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef" },
    "repair_kind": { "type": "string", "enum": ["copy_from_verified_replica", "reconstruct_from_chunks", "provider_native_restore", "backup_restore", "reupload", "manual_repair", "other"] },
    "production_correlation": { "$ref": "urn:ptah:schema:object:definitions:0.1.0#/$defs/productionCorrelation" },
    "pre_repair_verification_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef" },
      "uniqueItems": true
    },
    "post_repair_verification_refs": {
      "type": "array",
      "items": { "$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef" },
      "uniqueItems": true
    },
    "outcome": { "type": "string", "enum": ["repaired_and_verified", "repaired_unverified", "partial", "failed", "blocked", "cancelled"] },
    "receipt_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef" },
      "uniqueItems": true
    },
    "limitations": { "$ref": "urn:ptah:schema:object:definitions:0.1.0#/$defs/stringList" },
    "extensions": { "$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/extensions" }
  },
  "allOf": [
    {
      "if": { "properties": { "outcome": { "const": "repaired_and_verified" } }, "required": ["outcome"] },
      "then": { "properties": { "post_repair_verification_refs": { "minItems": 1 } } }
    }
  ]
}