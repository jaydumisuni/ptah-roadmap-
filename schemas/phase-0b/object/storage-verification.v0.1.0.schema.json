{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:ptah:schema:storage:verification:0.1.0",
  "title": "Ptah Storage Verification",
  "description": "Immutable verification check over exact Content and Storage Location.",
  "x-ptah-schema-name": "storage.verification",
  "x-ptah-schema-version": "0.1.0",
  "x-ptah-maturity": "candidate",
  "type": "object",
  "additionalProperties": false,
  "required": ["envelope", "verification_contract_version", "content_ref", "location_ref", "expected_digest", "expected_size", "observed_digest", "observed_size", "outcome", "verifier_ref", "verifier_version", "verified_at", "production_correlation", "receipt_refs", "limitations", "extensions"],
  "properties": {
    "envelope": {
      "allOf": [
        { "$ref": "urn:ptah:schema:common:entity-envelope:0.1.0" },
        { "properties": { "entity_kind": { "const": "storage.verification" } } }
      ]
    },
    "verification_contract_version": { "$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/semver" },
    "content_ref": { "$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef" },
    "location_ref": { "$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef" },
    "expected_digest": { "$ref": "urn:ptah:schema:object:definitions:0.1.0#/$defs/qualifiedDigest" },
    "expected_size": { "$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/nonNegativeInteger" },
    "observed_digest": {
      "oneOf": [
        { "$ref": "urn:ptah:schema:object:definitions:0.1.0#/$defs/qualifiedDigest" },
        { "type": "null" }
      ]
    },
    "observed_size": {
      "oneOf": [
        { "$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/nonNegativeInteger" },
        { "type": "null" }
      ]
    },
    "outcome": { "$ref": "urn:ptah:schema:object:definitions:0.1.0#/$defs/storageVerificationOutcome" },
    "verifier_ref": { "$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef" },
    "verifier_version": { "type": "string", "minLength": 1, "maxLength": 256 },
    "verified_at": { "$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/utcDateTime" },
    "production_correlation": { "$ref": "urn:ptah:schema:object:definitions:0.1.0#/$defs/productionCorrelation" },
    "receipt_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef" },
      "uniqueItems": true
    },
    "limitations": { "$ref": "urn:ptah:schema:object:definitions:0.1.0#/$defs/stringList" },
    "extensions": { "$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/extensions" }
  },
  "allOf": [
    {
      "if": { "properties": { "outcome": { "const": "verified" } }, "required": ["outcome"] },
      "then": {
        "properties": {
          "observed_digest": { "$ref": "urn:ptah:schema:object:definitions:0.1.0#/$defs/qualifiedDigest" },
          "observed_size": { "$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/nonNegativeInteger" }
        }
      }
    }
  ]
}