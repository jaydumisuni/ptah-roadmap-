{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:ptah:schema:object:preview:0.1.0",
  "title": "Ptah Object Preview",
  "description": "Human-oriented derived representation over exact source Revision(s).",
  "x-ptah-schema-name": "object.preview",
  "x-ptah-schema-version": "0.1.0",
  "x-ptah-maturity": "candidate",
  "type": "object",
  "additionalProperties": false,
  "required": ["envelope", "preview_contract_version", "preview_kind", "source_revision_refs", "output_revision_ref", "renderer_ref", "renderer_version", "settings", "production_correlation", "coverage", "limitations", "extensions"],
  "properties": {
    "envelope": {
      "allOf": [
        { "$ref": "urn:ptah:schema:common:entity-envelope:0.1.0" },
        { "properties": { "entity_kind": { "const": "object.preview" } } }
      ]
    },
    "preview_contract_version": { "$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/semver" },
    "preview_kind": { "type": "string", "enum": ["thumbnail", "page_render", "contact_sheet", "frame", "animated_sample", "waveform", "audio_sample", "syntax_highlight", "structure_map", "other"] },
    "source_revision_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef" },
      "uniqueItems": true
    },
    "output_revision_ref": { "$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef" },
    "renderer_ref": { "$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef" },
    "renderer_version": { "type": "string", "minLength": 1, "maxLength": 256 },
    "settings": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "width": { "type": "integer", "minimum": 1 },
        "height": { "type": "integer", "minimum": 1 },
        "duration_seconds": { "type": "number", "minimum": 0 },
        "range": { "$ref": "urn:ptah:schema:object:definitions:0.1.0#/$defs/locator" },
        "color_space": { "type": "string", "maxLength": 128 },
        "font_environment": { "type": "string", "maxLength": 512 },
        "codec_or_format": { "type": "string", "maxLength": 128 }
      }
    },
    "production_correlation": { "$ref": "urn:ptah:schema:object:definitions:0.1.0#/$defs/productionCorrelation" },
    "coverage": { "$ref": "urn:ptah:schema:object:definitions:0.1.0#/$defs/coverage" },
    "limitations": { "$ref": "urn:ptah:schema:object:definitions:0.1.0#/$defs/stringList" },
    "extensions": { "$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/extensions" }
  }
}