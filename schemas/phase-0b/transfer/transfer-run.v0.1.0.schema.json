{
  "$schema":"https://json-schema.org/draft/2020-12/schema",
  "$id":"urn:ptah:schema:transfer:transfer-run:0.1.0",
  "title":"Ptah Transfer Run",
  "x-ptah-schema-name":"transfer.transfer-run",
  "x-ptah-schema-version":"0.1.0",
  "x-ptah-maturity":"candidate",
  "type":"object","additionalProperties":false,
  "required":["envelope","lifecycle","request_ref","activity_ref","operation_ref","transfer_mode","source","destination","idempotency_key","correlation_nonce","attempt_refs","manifest_refs","progress_snapshot_refs","verification_refs","receipt_refs","created_at","extensions"],
  "properties":{
    "envelope":{"allOf":[{"$ref":"urn:ptah:schema:common:entity-envelope:0.1.0"},{"properties":{"entity_kind":{"const":"transfer.run"}}}]},
    "lifecycle":{"$ref":"urn:ptah:schema:transfer:definitions:0.1.0#/$defs/stateProjection"},
    "request_ref":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},
    "activity_ref":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},
    "operation_ref":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},
    "transfer_mode":{"$ref":"urn:ptah:schema:transfer:definitions:0.1.0#/$defs/transferMode"},
    "source":{"$ref":"urn:ptah:schema:transfer:definitions:0.1.0#/$defs/sourceDescriptor"},
    "destination":{"$ref":"urn:ptah:schema:transfer:definitions:0.1.0#/$defs/destinationDescriptor"},
    "idempotency_key":{"type":"string","pattern":"^[A-Za-z0-9._:-]{8,512}$"},
    "correlation_nonce":{"type":"string","pattern":"^[A-Za-z0-9._:-]{8,512}$"},
    "source_provider_generation":{"type":"integer","minimum":0},
    "destination_provider_generation":{"type":"integer","minimum":0},
    "attempt_refs":{"type":"array","items":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},"uniqueItems":true},
    "manifest_refs":{"type":"array","items":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},"uniqueItems":true},
    "progress_snapshot_refs":{"type":"array","items":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},"uniqueItems":true},
    "verification_refs":{"type":"array","items":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},"uniqueItems":true},
    "partial_location_or_alias_refs":{"type":"array","items":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},"uniqueItems":true},
    "accepted_content_ref":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},
    "accepted_object_revision_ref":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},
    "accepted_location_ref":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},
    "receipt_refs":{"type":"array","items":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},"uniqueItems":true},
    "created_at":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/utcDateTime"},
    "started_at":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/utcDateTime"},
    "completed_at":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/utcDateTime"},
    "limitations":{"type":"array","items":{"type":"string","minLength":1,"maxLength":4096}},
    "extensions":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/extensions"}
  }
}