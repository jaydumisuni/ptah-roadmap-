    "destination_provider_generation":{"type":"integer","minimum":0},
    "domain_results":{"type":"array","minItems":1,"items":{"type":"object","additionalProperties":false,"required":["domain","result","evidence_refs"],"properties":{"domain":{"$ref":"urn:ptah:schema:transfer:definitions:0.1.0#/$defs/transferVerificationDomain"},"result":{"type":"string","enum":["passed","failed","partial","not_performed","unknown"]},"observed_size":{"type":"integer","minimum":0},"observed_digests":{"type":"array","items":{"$ref":"urn:ptah:schema:transfer:definitions:0.1.0#/$defs/digestValue"}},"evidence_refs":{"type":"array","items":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},"uniqueItems":true},"limitations":{"type":"array","items":{"type":"string","maxLength":4096}}}}},
    "accepted_content_ref":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},
