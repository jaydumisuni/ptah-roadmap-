    "excluded_or_failed_entries":{"type":"array","items":{"type":"object","additionalProperties":false,"required":["source_ref","reason_code","result"],"properties":{"source_ref":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},"reason_code":{"type":"string","pattern":"^[A-Z][A-Z0-9_]{2,127}$"},"result":{"type":"string","enum":["excluded_by_policy","unsupported","failed","missing","unknown"]},"evidence_refs":{"type":"array","items":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},"uniqueItems":true}}}},
