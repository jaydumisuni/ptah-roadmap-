{
  "$schema":"https://json-schema.org/draft/2020-12/schema",
  "$id":"urn:ptah:schema:transfer:backup-policy:0.1.0",
  "title":"Ptah Backup Policy",
  "x-ptah-schema-name":"transfer.backup-policy","x-ptah-schema-version":"0.1.0","x-ptah-maturity":"candidate",
  "type":"object","additionalProperties":false,
  "required":["envelope","lifecycle","policy_key","protected_scope_refs","strategy","trigger_or_schedule_ref","inclusion_rules","exclusion_rules","encryption_policy_ref","repository_requirement_refs","retention_policy_ref","verification_policy_ref","minimum_copy_count","failure_domain_requirements","created_at","extensions"],
  "properties":{
    "envelope":{"allOf":[{"$ref":"urn:ptah:schema:common:entity-envelope:0.1.0"},{"properties":{"entity_kind":{"const":"backup.policy"}}}]},
    "lifecycle":{"$ref":"urn:ptah:schema:transfer:definitions:0.1.0#/$defs/stateProjection"},
    "policy_key":{"type":"string","pattern":"^[a-z][a-z0-9_.-]{2,127}$"},
    "protected_scope_refs":{"type":"array","minItems":1,"items":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},"uniqueItems":true},
    "strategy":{"$ref":"urn:ptah:schema:transfer:definitions:0.1.0#/$defs/backupStrategy"},
    "trigger_or_schedule_ref":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},
    "consistency_target":{"type":"string","enum":["metadata_only","crash_consistent","filesystem_consistent","application_consistent","transaction_consistent","mixed"]},
    "inclusion_rules":{"type":"array","items":{"type":"string","minLength":1,"maxLength":2048}},
    "exclusion_rules":{"type":"array","items":{"type":"string","minLength":1,"maxLength":2048}},
    "encryption_policy_ref":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},
    "repository_requirement_refs":{"type":"array","minItems":1,"items":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},"uniqueItems":true},
    "retention_policy_ref":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},
    "verification_policy_ref":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},
    "minimum_copy_count":{"type":"integer","minimum":1},
    "failure_domain_requirements":{"type":"array","items":{"type":"string","pattern":"^[a-z][a-z0-9_.-]{2,127}$"},"uniqueItems":true},
    "geographic_or_legal_policy_refs":{"type":"array","items":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},"uniqueItems":true},
    "alert_or_failure_policy_refs":{"type":"array","items":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},"uniqueItems":true},
    "created_at":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/utcDateTime"},
    "limitations":{"type":"array","items":{"type":"string","maxLength":4096}},
    "extensions":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/extensions"}
  }
}