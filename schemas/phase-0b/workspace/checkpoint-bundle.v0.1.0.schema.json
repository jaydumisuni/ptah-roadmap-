{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:ptah:schema:workspace:checkpoint-bundle:0.1.0",
  "title": "Ptah Checkpoint Bundle",
  "x-ptah-schema-name": "workspace.checkpoint-bundle",
  "x-ptah-schema-version": "0.1.0",
  "x-ptah-maturity": "candidate",
  "type": "object",
  "additionalProperties": false,
  "required": ["envelope", "checkpoint_request_ref", "workspace_ref", "workspace_revision_ref", "component_entries", "declared_scope", "overall_consistency", "overall_completeness", "portability", "sensitivity", "manifest_object_or_artifact_ref", "verification_refs", "created_activity_ref", "created_attempt_ref", "receipt_refs", "created_at", "limitations", "extensions"],
  "properties": {
    "envelope": {"allOf": [{"$ref": "urn:ptah:schema:common:entity-envelope:0.1.0"}, {"properties": {"entity_kind": {"const": "runtime.checkpoint_bundle"}}}]},
    "checkpoint_request_ref": {"$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},
    "workspace_ref": {"$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},
    "workspace_revision_ref": {"$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},
    "workspace_materialization_ref": {"$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},
    "materialization_generation": {"$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/nonNegativeInteger"},
    "component_entries": {"type": "array", "minItems": 1, "items": {"$ref": "urn:ptah:schema:workspace:definitions:0.1.0#/$defs/componentEntry"}},
    "declared_scope": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1, "maxLength": 1024}, "uniqueItems": true},
    "overall_consistency": {"$ref": "urn:ptah:schema:workspace:definitions:0.1.0#/$defs/consistencyClass"},
    "overall_completeness": {"$ref": "urn:ptah:schema:workspace:definitions:0.1.0#/$defs/completenessClass"},
    "portability": {"$ref": "urn:ptah:schema:workspace:definitions:0.1.0#/$defs/portabilityClass"},
    "sensitivity": {"$ref": "urn:ptah:schema:workspace:definitions:0.1.0#/$defs/sensitivityClass"},
    "manifest_object_or_artifact_ref": {"$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},
    "location_refs": {"type": "array", "items": {"$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"}, "uniqueItems": true},
    "signature_or_encryption_refs": {"type": "array", "items": {"$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"}, "uniqueItems": true},
    "verification_refs": {"type": "array", "items": {"$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"}, "uniqueItems": true},
    "created_activity_ref": {"$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},
    "created_attempt_ref": {"$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},
    "receipt_refs": {"type": "array", "minItems": 1, "items": {"$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"}, "uniqueItems": true},
    "created_at": {"$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/utcDateTime"},
    "limitations": {"type": "array", "items": {"type": "string", "minLength": 1, "maxLength": 4096}},
    "extensions": {"$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/extensions"}
  },
  "allOf": [
    {"if": {"properties": {"overall_completeness": {"const": "complete_for_declared_scope"}}, "required": ["overall_completeness"]}, "then": {"not": {"properties": {"sensitivity": {"const": "unknown_sensitive_content"}}, "required": ["sensitivity"]}}},
    {"if": {"required": ["workspace_materialization_ref"]}, "then": {"required": ["materialization_generation"]}}
  ]
}