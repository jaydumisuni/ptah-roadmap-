{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:ptah:schema:workspace:restore-compatibility:0.1.0",
  "title": "Ptah Restore Compatibility Decision",
  "x-ptah-schema-name": "workspace.restore-compatibility",
  "x-ptah-schema-version": "0.1.0",
  "x-ptah-maturity": "candidate",
  "type": "object",
  "additionalProperties": false,
  "required": ["envelope", "checkpoint_bundle_ref", "target_workspace_revision_ref", "target_provider_revision_ref", "target_provider_instance_ref", "target_provider_generation", "target_locality", "evaluated_at", "valid_until", "decision", "requirement_results", "policy_refs", "evidence_refs", "limitations", "extensions"],
  "properties": {
    "envelope": {"allOf": [{"$ref": "urn:ptah:schema:common:entity-envelope:0.1.0"}, {"properties": {"entity_kind": {"const": "runtime.restore_compatibility"}}}]},
    "checkpoint_bundle_ref": {"$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},
    "target_workspace_ref": {"$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},
    "target_workspace_revision_ref": {"$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},
    "target_provider_revision_ref": {"$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},
    "target_provider_instance_ref": {"$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},
    "target_provider_generation": {"$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/nonNegativeInteger"},
    "target_locality": {"type": "string", "enum": ["node_local", "remote_service"]},
    "target_node_ref": {"$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},
    "target_node_generation": {"$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/nonNegativeInteger"},
    "target_remote_service_ref": {"$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},
    "node_capability_snapshot_ref": {"$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},
    "node_resource_snapshot_ref": {"$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},
    "provider_capability_snapshot_ref": {"$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},
    "evaluated_at": {"$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/utcDateTime"},
    "valid_until": {"$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/utcDateTime"},
    "decision": {"$ref": "urn:ptah:schema:workspace:definitions:0.1.0#/$defs/compatibilityDecision"},
    "requirement_results": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["requirement_key", "result", "evidence_refs"],
        "properties": {
          "requirement_key": {"type": "string", "pattern": "^[a-z][a-z0-9_.-]{2,127}$"},
          "result": {"type": "string", "enum": ["satisfied", "satisfied_with_conversion", "unsatisfied", "unknown", "stale"]},
          "conversion_or_condition_refs": {"type": "array", "items": {"$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"}, "uniqueItems": true},
          "evidence_refs": {"type": "array", "items": {"$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"}, "uniqueItems": true},
          "reason": {"type": "string", "minLength": 1, "maxLength": 4096}
        }
      }
    },
    "component_decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["checkpoint_component_ref", "decision", "evidence_refs"],
        "properties": {
          "checkpoint_component_ref": {"$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},
          "decision": {"$ref": "urn:ptah:schema:workspace:definitions:0.1.0#/$defs/compatibilityDecision"},
          "conversion_or_condition_refs": {"type": "array", "items": {"$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"}, "uniqueItems": true},
          "evidence_refs": {"type": "array", "items": {"$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"}, "uniqueItems": true},
          "limitations": {"type": "array", "items": {"type": "string", "minLength": 1, "maxLength": 4096}}
        }
      }
    },
    "policy_refs": {"type": "array", "items": {"$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"}, "minItems": 1, "uniqueItems": true},
    "evidence_refs": {"type": "array", "items": {"$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"}, "minItems": 1, "uniqueItems": true},
    "receipt_refs": {"type": "array", "items": {"$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"}, "uniqueItems": true},
    "limitations": {"type": "array", "items": {"type": "string", "minLength": 1, "maxLength": 4096}},
    "extensions": {"$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/extensions"}
  },
  "allOf": [
    {
      "if": {"properties": {"target_locality": {"const": "node_local"}}},
      "then": {"required": ["target_node_ref", "target_node_generation", "node_capability_snapshot_ref", "node_resource_snapshot_ref"], "not": {"required": ["target_remote_service_ref"]}},
      "else": {"required": ["target_remote_service_ref"], "not": {"anyOf": [{"required": ["target_node_ref"]}, {"required": ["target_node_generation"]}]}}
    }
  ]
}