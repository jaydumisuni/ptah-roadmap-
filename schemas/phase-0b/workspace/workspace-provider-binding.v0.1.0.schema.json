{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:ptah:schema:workspace:workspace-provider-binding:0.1.0",
  "title": "Ptah Workspace Provider Binding",
  "x-ptah-schema-name": "workspace.workspace-provider-binding",
