{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:ptah:schema:workspace:checkpoint-verification:0.1.0",
  "title": "Ptah Checkpoint Verification",
  "x-ptah-schema-name": "workspace.checkpoint-verification",
  "x-ptah-schema-version": "0.1.0",
  "x-ptah-maturity": "candidate",
  "type": "object",
  "additionalProperties": false,
  "required": ["envelope", "checkpoint_bundle_ref", "verification_state", "protocol_ref", "activity_ref", "operation_ref", "attempt_ref", "manifest_valid", "required_components_present", "component_results", "privacy_policy_result", "observed_at", "receipt_refs", "limitations", "extensions"],
  "properties": {
    "envelope": {"allOf": [{"$ref": "urn:ptah:schema:common:entity-envelope:0.1.0"}, {"properties": {"entity_kind": {"const": "runtime.checkpoint_verification"}}}]},
    "checkpoint_bundle_ref": {"$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},
    "verification_state": {"type": "string", "enum": ["verified", "failed", "partial", "inconclusive"]},
    "protocol_ref": {"$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},
    "tool_or_provider_revision_ref": {"$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},
    "activity_ref": {"$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},
    "operation_ref": {"$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},
    "attempt_ref": {"$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},
    "manifest_valid": {"type": "boolean"},
    "required_components_present": {"type": "boolean"},
    "component_results": {"type": "array", "items": {"type": "object", "additionalProperties": false, "required": ["component_ref", "integrity_state", "readback_state", "evidence_refs"], "properties": {"component_ref": {"$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"}, "integrity_state": {"type": "string", "enum": ["verified", "failed", "unknown"]}, "readback_state": {"type": "string", "enum": ["verified", "failed", "not_performed", "unknown"]}, "evidence_refs": {"type": "array", "items": {"$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"}, "uniqueItems": true}, "limitations": {"type": "array", "items": {"type": "string", "maxLength": 4096}}}}, "minItems": 1},
    "signature_or_encryption_result_refs": {"type": "array", "items": {"$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"}, "uniqueItems": true},
    "consistency_evidence_refs": {"type": "array", "items": {"$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"}, "uniqueItems": true},
    "privacy_policy_result": {"type": "string", "enum": ["passed", "failed", "partial", "unknown"]},
    "observed_at": {"$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/utcDateTime"},
    "receipt_refs": {"type": "array", "minItems": 1, "items": {"$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"}, "uniqueItems": true},
    "evidence_refs": {"type": "array", "items": {"$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"}, "uniqueItems": true},
    "limitations": {"type": "array", "items": {"type": "string", "minLength": 1, "maxLength": 4096}},
    "extensions": {"$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/extensions"}
  }
}