{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:ptah:schema:activity:verdict:0.1.0",
  "title": "Ptah Verdict",
  "description": "Immutable conclusion produced by a Review over exact subjects and evidence.",
  "x-ptah-schema-name": "activity.verdict",
  "x-ptah-schema-version": "0.1.0",
  "x-ptah-maturity": "candidate",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "envelope",
    "review_ref",
    "subject_refs",
    "verdict",
    "summary",
    "limitations",
    "evidence_refs",
    "issued_by_ref",
    "issued_at",
    "extensions"
  ],
  "properties": {
    "envelope": {
      "allOf": [
        { "$ref": "urn:ptah:schema:common:entity-envelope:0.1.0" },
        { "properties": { "entity_kind": { "const": "proof.verdict" } } }
      ]
    },
    "review_ref": { "$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef" },
    "subject_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef" },
      "uniqueItems": true
    },
    "subject_hashes": {
      "type": "array",
      "items": { "$ref": "urn:ptah:schema:activity:definitions:0.1.0#/$defs/contentHash" },
      "uniqueItems": true
    },
    "verdict": { "$ref": "urn:ptah:schema:activity:definitions:0.1.0#/$defs/verdict" },
    "summary": { "type": "string", "minLength": 1, "maxLength": 8192 },
    "conditions": {
      "type": "array",
      "items": { "type": "string", "minLength": 1, "maxLength": 4096 }
    },
    "limitations": {
      "type": "array",
      "items": { "type": "string", "minLength": 1, "maxLength": 4096 }
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef" },
      "uniqueItems": true
    },
    "issued_by_ref": { "$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef" },
    "issued_at": { "$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/utcDateTime" },
    "supersedes_verdict_ref": { "$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef" },
    "extensions": { "$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/extensions" }
  },
  "allOf": [
    {
      "if": { "properties": { "verdict": { "const": "conditional" } }, "required": ["verdict"] },
      "then": { "required": ["conditions"], "properties": { "conditions": { "minItems": 1 } } }
    }
  ]
}
