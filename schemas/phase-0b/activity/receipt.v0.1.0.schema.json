{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:ptah:schema:activity:receipt:0.1.0",
  "title": "Ptah Operation Receipt",
  "description": "Append-only durable evidence from an identified producer for an exact Activity, Operation and Attempt.",
  "x-ptah-schema-name": "activity.receipt",
  "x-ptah-schema-version": "0.1.0",
  "x-ptah-maturity": "candidate",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "envelope",
    "receipt_contract_version",
    "receipt_kind",
    "receipt_outcome",
    "authority_class",
    "activity_ref",
    "operation_ref",
    "attempt_ref",
    "idempotency_key",
    "correlation_nonce",
    "node_ref",
    "node_generation",
    "provider_ref",
    "provider_generation",
    "workload_generation",
    "connection_epoch",
    "facility_ref",
    "producer_instance_ref",
    "producer_version",
    "producer_identity_evidence_refs",
    "proof_claim_refs",
    "occurred_at",
    "observed_at",
    "received_at",
    "summary",
    "input_refs",
    "output_refs",
    "artifact_refs",
    "checkpoint_refs",
    "content_hashes",
    "event_refs",
    "previous_or_superseded_receipt_refs",
    "signature_or_attestation_refs",
    "limitations",
    "payload_class",
    "extensions"
  ],
  "properties": {
    "envelope": {
      "allOf": [
        { "$ref": "urn:ptah:schema:common:entity-envelope:0.1.0" },
        { "properties": { "entity_kind": { "const": "proof.receipt" } } }
      ]
    },
    "receipt_contract_version": { "$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/semver" },
    "receipt_kind": { "$ref": "urn:ptah:schema:activity:definitions:0.1.0#/$defs/receiptKind" },
    "receipt_outcome": { "$ref": "urn:ptah:schema:activity:definitions:0.1.0#/$defs/receiptOutcome" },
    "authority_class": { "$ref": "urn:ptah:schema:activity:definitions:0.1.0#/$defs/receiptAuthorityClass" },
    "activity_ref": { "$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef" },
    "operation_ref": { "$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef" },
    "attempt_ref": { "$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef" },
    "idempotency_key": {
      "oneOf": [
        { "$ref": "urn:ptah:schema:activity:definitions:0.1.0#/$defs/keyToken" },
        { "type": "null" }
      ]
    },
    "correlation_nonce": { "$ref": "urn:ptah:schema:activity:definitions:0.1.0#/$defs/keyToken" },
    "node_ref": { "$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef" },
    "node_generation": { "$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/nonNegativeInteger" },
    "provider_ref": { "$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef" },
    "provider_generation": { "$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/nonNegativeInteger" },
    "workload_generation": { "$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/nonNegativeInteger" },
    "connection_epoch": { "$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/nonNegativeInteger" },
    "facility_ref": { "$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef" },
    "producer_instance_ref": { "$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef" },
    "producer_version": { "type": "string", "minLength": 1, "maxLength": 256 },
    "producer_identity_evidence_refs": {
      "type": "array",
      "items": { "$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef" },
      "uniqueItems": true
    },
    "proof_claim_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef" },
      "uniqueItems": true
    },
    "occurred_at": { "$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/utcDateTime" },
    "observed_at": { "$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/utcDateTime" },
    "received_at": { "$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/utcDateTime" },
    "summary": { "type": "string", "minLength": 1, "maxLength": 8192 },
    "input_refs": {
      "type": "array",
      "items": { "$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef" },
      "uniqueItems": true
    },
    "output_refs": {
      "type": "array",
      "items": { "$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef" },
      "uniqueItems": true
    },
    "artifact_refs": {
      "type": "array",
      "items": { "$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef" },
      "uniqueItems": true
    },
    "checkpoint_refs": {
      "type": "array",
      "items": { "$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef" },
      "uniqueItems": true
    },
    "content_hashes": {
      "type": "array",
      "items": { "$ref": "urn:ptah:schema:activity:definitions:0.1.0#/$defs/contentHash" },
      "uniqueItems": true
    },
    "command_or_action_ref": { "$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef" },
    "result_ref": { "$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef" },
    "trace_context": { "$ref": "urn:ptah:schema:activity:definitions:0.1.0#/$defs/traceContext" },
    "event_refs": {
      "type": "array",
      "items": { "$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef" },
      "uniqueItems": true
    },
    "previous_or_superseded_receipt_refs": {
      "type": "array",
      "items": { "$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef" },
      "uniqueItems": true
    },
    "signature_or_attestation_refs": {
      "type": "array",
      "items": { "$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef" },
      "uniqueItems": true
    },
    "limitations": {
      "type": "array",
      "items": { "type": "string", "minLength": 1, "maxLength": 4096 }
    },
    "payload_class": { "$ref": "urn:ptah:schema:activity:definitions:0.1.0#/$defs/eventPayloadClass" },
    "payload_schema_id": { "$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/schemaId" },
    "payload_schema_version": { "$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/semver" },
    "inline_payload": { "$ref": "urn:ptah:schema:activity:definitions:0.1.0#/$defs/smallPayload" },
    "payload_ref": { "$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef" },
    "stream_ref": { "$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef" },
    "extensions": { "$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/extensions" }
  },
  "allOf": [
    {
      "if": { "properties": { "receipt_kind": { "const": "correction" } }, "required": ["receipt_kind"] },
      "then": { "properties": { "previous_or_superseded_receipt_refs": { "minItems": 1 } } }
    },
    {
      "if": { "properties": { "receipt_outcome": { "enum": ["corrected", "superseded"] } }, "required": ["receipt_outcome"] },
      "then": { "properties": { "previous_or_superseded_receipt_refs": { "minItems": 1 } } }
    },
    {
      "if": { "properties": { "payload_class": { "const": "inline_small" } }, "required": ["payload_class"] },
      "then": { "required": ["payload_schema_id", "payload_schema_version", "inline_payload"] }
    },
    {
      "if": { "properties": { "payload_class": { "enum": ["object_reference", "artifact_reference"] } }, "required": ["payload_class"] },
      "then": { "required": ["payload_schema_id", "payload_schema_version", "payload_ref"] }
    },
    {
      "if": { "properties": { "payload_class": { "const": "stream_reference" } }, "required": ["payload_class"] },
      "then": { "required": ["stream_ref"] }
    },
    {
      "if": { "properties": { "payload_class": { "const": "none" } }, "required": ["payload_class"] },
      "then": {
        "not": {
          "anyOf": [
            { "required": ["inline_payload"] },
            { "required": ["payload_ref"] },
            { "required": ["stream_ref"] }
          ]
        }
      }
    }
  ]
}
