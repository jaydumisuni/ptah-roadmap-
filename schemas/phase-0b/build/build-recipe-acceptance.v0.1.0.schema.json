{
  "$schema":"https://json-schema.org/draft/2020-12/schema",
  "$id":"urn:ptah:schema:build:build-recipe-acceptance:0.1.0",
  "title":"Ptah Build Recipe Acceptance",
  "x-ptah-schema-name":"build.build-recipe-acceptance",
  "x-ptah-schema-version":"0.1.0",
  "x-ptah-maturity":"candidate",
  "type":"object",
  "additionalProperties":false,
  "required":["envelope","recipe_revision_ref","proposal_ref","decision","decided_by_ref","policy_refs","evidence_refs","decided_at","extensions"],
  "properties":{
    "envelope":{"allOf":[{"$ref":"urn:ptah:schema:common:entity-envelope:0.1.0"},{"properties":{"entity_kind":{"const":"build.recipe_acceptance"}}}]},
    "recipe_revision_ref":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},
    "proposal_ref":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},
    "decision":{"$ref":"urn:ptah:schema:build:definitions:0.1.0#/$defs/acceptanceDecision"},
    "decided_by_ref":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},
    "policy_refs":{"type":"array","minItems":1,"items":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},"uniqueItems":true},
    "condition_refs":{"type":"array","items":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},"uniqueItems":true},
    "evidence_refs":{"type":"array","minItems":1,"items":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},"uniqueItems":true},
    "valid_until":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/utcDateTime"},
    "decided_at":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/utcDateTime"},
    "reason":{"type":"string","minLength":1,"maxLength":4096},
    "limitations":{"type":"array","items":{"type":"string","minLength":1,"maxLength":4096}},
    "extensions":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/extensions"}
  },
  "allOf":[{"if":{"properties":{"decision":{"const":"accepted_with_conditions"}}},"then":{"required":["condition_refs"],"properties":{"condition_refs":{"minItems":1}}}}]
}