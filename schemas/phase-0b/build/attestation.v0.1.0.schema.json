{
  "$schema":"https://json-schema.org/draft/2020-12/schema",
  "$id":"urn:ptah:schema:build:attestation:0.1.0",
  "title":"Ptah Provenance Attestation",
  "x-ptah-schema-name":"build.attestation",
  "x-ptah-schema-version":"0.1.0",
  "x-ptah-maturity":"candidate",
  "type":"object",
  "additionalProperties":false,
  "required":["envelope","subject_refs","subject_digest_refs","predicate_type","predicate_version","statement_artifact_ref","producer_ref","producer_facility_revision_ref","materials","products","created_at","activity_ref","operation_ref","attempt_ref","receipt_refs","extensions"],
  "properties":{
    "envelope":{"allOf":[{"$ref":"urn:ptah:schema:common:entity-envelope:0.1.0"},{"properties":{"entity_kind":{"const":"provenance.attestation"}}}]},
    "subject_refs":{"type":"array","minItems":1,"items":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},"uniqueItems":true},
    "subject_digest_refs":{"type":"array","minItems":1,"items":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},"uniqueItems":true},
    "predicate_type":{"type":"string","format":"uri"},
    "predicate_version":{"type":"string","minLength":1,"maxLength":128},
    "statement_artifact_ref":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},
    "envelope_type":{"type":"string","enum":["unsigned_statement","dsse","in_toto_statement","other_registered"]},
    "producer_ref":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},
    "producer_facility_revision_ref":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},
    "producer_provider_revision_ref":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},
    "build_run_ref":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},
    "materials":{"type":"array","items":{"type":"object","additionalProperties":false,"required":["subject_ref","origin"],"properties":{"subject_ref":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},"origin":{"type":"string","enum":["declared","observed","both","unknown"]},"digest_refs":{"type":"array","items":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},"uniqueItems":true}}}},
    "products":{"type":"array","items":{"type":"object","additionalProperties":false,"required":["subject_ref","origin"],"properties":{"subject_ref":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},"origin":{"type":"string","enum":["declared","observed","both","unknown"]},"digest_refs":{"type":"array","items":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},"uniqueItems":true}}}},
    "signature_refs":{"type":"array","items":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},"uniqueItems":true},
    "created_at":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/utcDateTime"},
    "activity_ref":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},
    "operation_ref":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},
    "attempt_ref":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},
    "receipt_refs":{"type":"array","minItems":1,"items":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},"uniqueItems":true},
    "limitations":{"type":"array","items":{"type":"string","minLength":1,"maxLength":4096}},
    "extensions":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/extensions"}
  }
}