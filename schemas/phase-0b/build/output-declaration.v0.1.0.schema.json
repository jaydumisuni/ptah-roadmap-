{
  "$schema":"https://json-schema.org/draft/2020-12/schema",
  "$id":"urn:ptah:schema:build:output-declaration:0.1.0",
  "title":"Ptah Build Output Declaration",
  "x-ptah-schema-name":"build.output-declaration",
  "x-ptah-schema-version":"0.1.0",
  "x-ptah-maturity":"candidate",
  "type":"object",
  "additionalProperties":false,
  "required":["envelope","recipe_revision_ref","output_key","output_role","expected_type_or_media","required","privacy_class","audience","retention_policy_refs","proof_requirements","extensions"],
  "properties":{
    "envelope":{"allOf":[{"$ref":"urn:ptah:schema:common:entity-envelope:0.1.0"},{"properties":{"entity_kind":{"const":"build.output_declaration"}}}]},
    "recipe_revision_ref":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},
    "step_key":{"type":"string","pattern":"^[a-z][a-z0-9_.-]{1,127}$"},
    "output_key":{"type":"string","pattern":"^[a-z][a-z0-9_.-]{1,127}$"},
    "output_role":{"$ref":"urn:ptah:schema:build:definitions:0.1.0#/$defs/outputRole"},
    "expected_type_or_media":{"type":"array","minItems":1,"items":{"type":"string","minLength":1,"maxLength":256},"uniqueItems":true},
    "platform_or_variant":{"type":"string","maxLength":256},
    "selector_or_path_hint":{"type":"string","maxLength":2048},
    "required":{"type":"boolean"},
    "artifact_promotion_required":{"type":"boolean"},
    "artifact_type":{"type":"string","pattern":"^[a-z][a-z0-9_.-]{2,127}$"},
    "acceptance_protocol_refs":{"type":"array","items":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},"uniqueItems":true},
    "privacy_class":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/privacyClass"},
    "audience":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/audience"},
    "retention_policy_refs":{"type":"array","minItems":1,"items":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},"uniqueItems":true},
    "destination_requirement_refs":{"type":"array","items":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},"uniqueItems":true},
    "proof_requirements":{"type":"array","items":{"$ref":"urn:ptah:schema:build:definitions:0.1.0#/$defs/proofRequirement"}},
    "limitations":{"type":"array","items":{"type":"string","minLength":1,"maxLength":4096}},
    "extensions":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/extensions"}
  }
}