{
  "$schema":"https://json-schema.org/draft/2020-12/schema",
  "$id":"urn:ptah:schema:build:signature-verification:0.1.0",
  "title":"Ptah Signature Verification",
  "x-ptah-schema-name":"build.signature-verification",
  "x-ptah-schema-version":"0.1.0",
  "x-ptah-maturity":"candidate",
  "type":"object",
  "additionalProperties":false,
  "required":["envelope","signature_ref","subject_ref","subject_digest_refs","verifier_revision_ref","trust_policy_ref","decision","verified_at","requirement_results","activity_ref","operation_ref","attempt_ref","receipt_refs","extensions"],
  "properties":{
    "envelope":{"allOf":[{"$ref":"urn:ptah:schema:common:entity-envelope:0.1.0"},{"properties":{"entity_kind":{"const":"provenance.signature_verification"}}}]},
    "signature_ref":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},
    "subject_ref":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},
    "subject_digest_refs":{"type":"array","minItems":1,"items":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},"uniqueItems":true},
    "verifier_revision_ref":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},
    "trust_policy_ref":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},
    "trusted_root_refs":{"type":"array","minItems":1,"items":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},"uniqueItems":true},
    "certificate_or_identity_refs":{"type":"array","items":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},"uniqueItems":true},
    "transparency_evidence_refs":{"type":"array","items":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},"uniqueItems":true},
    "offline_bundle_ref":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},
    "requirement_results":{"type":"array","minItems":1,"items":{"$ref":"urn:ptah:schema:build:definitions:0.1.0#/$defs/requirementResult"}},
    "decision":{"$ref":"urn:ptah:schema:build:definitions:0.1.0#/$defs/verificationDecision"},
    "verified_at":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/utcDateTime"},
    "valid_until":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/utcDateTime"},
    "activity_ref":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},
    "operation_ref":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},
    "attempt_ref":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},
    "receipt_refs":{"type":"array","minItems":1,"items":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},"uniqueItems":true},
    "limitations":{"type":"array","items":{"type":"string","minLength":1,"maxLength":4096}},
    "extensions":{"$ref":"urn:ptah:schema:common:definitions:0.1.0#/$defs/extensions"}
  }
