{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:ptah:schema:runtime:provider-revision:0.1.0",
  "title": "Ptah Provider Revision",
  "x-ptah-schema-name": "runtime.provider-revision",
  "x-ptah-schema-version": "0.1.0",
  "x-ptah-maturity": "candidate",
  "type": "object",
  "additionalProperties": false,
  "required": ["envelope", "provider_ref", "provider_kind", "implementation_name", "implementation_version", "build_or_package_digest", "configuration_digest", "supported_facility_ranges", "capability_claim_refs", "dependencies", "node_requirements", "security_requirements", "known_limitations", "extensions"],
  "properties": {
    "envelope": {"allOf": [{"$ref": "urn:ptah:schema:common:entity-envelope:0.1.0"}, {"properties": {"entity_kind": {"const": "runtime.provider_revision"}}}]},
    "provider_ref": {"$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},
    "provider_kind": {"$ref": "urn:ptah:schema:runtime:definitions:0.1.0#/$defs/providerKind"},
    "implementation_name": {"type": "string", "minLength": 1, "maxLength": 256},
    "implementation_version": {"type": "string", "minLength": 1, "maxLength": 256},
    "build_or_package_digest": {"type": "string", "pattern": "^[a-z0-9][a-z0-9:+._-]{3,255}$"},
    "configuration_digest": {"type": "string", "pattern": "^[a-z0-9][a-z0-9:+._-]{3,255}$"},
    "source_or_package_refs": {"type": "array", "items": {"$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"}, "uniqueItems": true},
    "supported_facility_ranges": {"type": "array", "items": {"$ref": "urn:ptah:schema:runtime:definitions:0.1.0#/$defs/compatibilityRange"}, "minItems": 1},
    "capability_claim_refs": {"type": "array", "items": {"$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"}, "uniqueItems": true},
    "supported_architectures": {"type": "array", "items": {"type": "string", "enum": ["x86_64", "aarch64", "armv7", "riscv64", "other"]}, "uniqueItems": true},
    "supported_os_families": {"type": "array", "items": {"type": "string", "enum": ["linux", "windows", "macos", "android", "ios", "other"]}, "uniqueItems": true},
    "dependencies": {"type": "array", "items": {"$ref": "urn:ptah:schema:runtime:definitions:0.1.0#/$defs/dependencyRequirement"}},
    "node_requirements": {"type": "array", "items": {"type": "string", "minLength": 1, "maxLength": 1024}},
    "security_requirements": {"type": "array", "items": {"type": "string", "minLength": 1, "maxLength": 1024}},
    "network_requirement_refs": {"type": "array", "items": {"$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"}, "uniqueItems": true},
    "credential_requirement_refs": {"type": "array", "items": {"$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"}, "uniqueItems": true},
    "device_requirement_refs": {"type": "array", "items": {"$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"}, "uniqueItems": true},
    "object_access_requirement_refs": {"type": "array", "items": {"$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"}, "uniqueItems": true},
    "checkpoint_capability_refs": {"type": "array", "items": {"$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"}, "uniqueItems": true},
    "licence_and_provenance_refs": {"type": "array", "items": {"$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"}, "uniqueItems": true},
    "known_limitations": {"type": "array", "items": {"type": "string", "minLength": 1, "maxLength": 4096}},
    "extensions": {"$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/extensions"}
  }
}