{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:ptah:schema:runtime:capability-claim:0.1.0",
  "title": "Ptah Capability Claim",
  "x-ptah-schema-name": "runtime.capability-claim",
  "x-ptah-schema-version": "0.1.0",
  "x-ptah-maturity": "candidate",
  "type": "object",
  "additionalProperties": false,
  "required": ["envelope", "subject_kind", "subject_ref", "capability_ref", "claimant_ref", "claimed_at", "evidence_refs", "limitations", "extensions"],
  "properties": {
    "envelope": {"allOf": [{"$ref": "urn:ptah:schema:common:entity-envelope:0.1.0"}, {"properties": {"entity_kind": {"const": "core.capability_claim"}}}]},
    "subject_kind": {"$ref": "urn:ptah:schema:runtime:definitions:0.1.0#/$defs/capabilitySubjectKind"},
    "subject_ref": {"$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},
    "subject_node_generation": {"$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/nonNegativeInteger"},
    "subject_provider_generation": {"$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/nonNegativeInteger"},
    "capability_ref": {"$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},
    "claimed_minimum_version": {"$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/semver"},
    "claimed_maximum_version_inclusive": {"$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/semver"},
    "claimant_ref": {"$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"},
    "configuration_digest": {"type": "string", "pattern": "^[a-z0-9][a-z0-9:+._-]{3,255}$"},
    "claimed_at": {"$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/utcDateTime"},
    "valid_until": {"$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/utcDateTime"},
    "evidence_refs": {"type": "array", "items": {"$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"}, "uniqueItems": true},
    "receipt_refs": {"type": "array", "items": {"$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/entityRef"}, "uniqueItems": true},
    "limitations": {"type": "array", "items": {"type": "string", "minLength": 1, "maxLength": 4096}},
    "extensions": {"$ref": "urn:ptah:schema:common:definitions:0.1.0#/$defs/extensions"}
  }
}