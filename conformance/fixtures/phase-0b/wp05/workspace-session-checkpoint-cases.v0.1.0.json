{
  "suite_id": "ptah.conformance.workspace-session-checkpoint.0.1.0",
  "fixture_version": "0.1.0",
  "fixture_class": "cross_record_scenarios",
  "execution_status": "specification_only_until_wp13",
  "cases": [
    {"id":"W01_VALID_ACTIVE_WITHOUT_MATERIALIZATION","expected":"valid","schemas":["urn:ptah:schema:workspace:workspace:0.1.0"],"setup":"An active Workspace has a current Revision but no running materialization.","assertions":["Workspace identity/lifecycle remain valid","no runtime state fabricated"]},
    {"id":"W02_INVALID_PATH_AS_WORKSPACE_ID","expected":"invalid","expected_code":"ALIAS_USED_AS_WORKSPACE_IDENTITY","schemas":["urn:ptah:schema:workspace:workspace:0.1.0"],"setup":"Importer uses /home/user/project or a repository URL as canonical Workspace ID.","assertions":["reject identity","retain as alias/provenance"]},
    {"id":"W03_VALID_CONCURRENT_ACTIVITIES_SESSIONS","expected":"valid","schemas":["urn:ptah:schema:workspace:workspace:0.1.0","urn:ptah:schema:workspace:session:0.1.0"],"setup":"One Workspace contains unrelated build, browser, terminal and device Activities/Sessions.","assertions":["no single-current-task invariant","unrelated failure does not block all work"]},
    {"id":"W04_INVALID_MUTATED_REVISION","expected":"invalid","expected_code":"IMMUTABLE_WORKSPACE_REVISION_MUTATED","schemas":["urn:ptah:schema:workspace:workspace-revision:0.1.0"],"setup":"A frozen Workspace Revision is edited in place.","assertions":["create new revision","preserve parent/history"]},
    {"id":"W05_VALID_DIVERGENT_REVISIONS","expected":"valid","schemas":["urn:ptah:schema:workspace:workspace-revision:0.1.0"],"setup":"Two changes share one base Revision and later merge explicitly.","assertions":["both revisions retained","merge has both parents"]},
    {"id":"A01_INVALID_REVOKED_MEMBERSHIP_CONTROL","expected":"invalid","expected_code":"MEMBERSHIP_NOT_AUTHORIZED","schemas":["urn:ptah:schema:workspace:workspace-membership:0.1.0","urn:ptah:schema:workspace:session-attachment:0.1.0"],"setup":"Revoked/expired membership attempts new attachment or control.","assertions":["deny new authority","historical records retained"]},
    {"id":"A02_INVALID_MEMBERSHIP_EQUALS_CONTROL","expected":"invalid","expected_code":"CONTROL_LEASE_REQUIRED","schemas":["urn:ptah:schema:workspace:workspace-membership:0.1.0","urn:ptah:schema:workspace:session-attachment:0.1.0"],"setup":"Active membership is treated as exclusive input/control authority.","assertions":["membership may permit request","control Lease/fence still required"]},
    {"id":"B01_VALID_BINDING_PROVIDER_REPLACEMENT","expected":"valid","schemas":["urn:ptah:schema:workspace:workspace-provider-binding:0.1.0","urn:ptah:schema:workspace:workspace:0.1.0"],"setup":"Compatible Provider replacement changes binding/instance while Workspace identity remains.","assertions":["Workspace ID unchanged","compatibility revalidated","history retained"]},
    {"id":"B02_INVALID_BINDING_AS_RUNNING_ENVIRONMENT","expected":"invalid","expected_code":"BINDING_NOT_MATERIALIZATION","schemas":["urn:ptah:schema:workspace:workspace-provider-binding:0.1.0"],"setup":"A validated binding is reported as a running Workspace.","assertions":["Materialization and execution evidence required"]},
    {"id":"M01_VALID_PROVIDER_RESTART_NEW_GENERATION","expected":"valid","schemas":["urn:ptah:schema:workspace:workspace-materialization:0.1.0"],"setup":"Provider restarts and creates a new Materialization generation under the same Workspace.","assertions":["Workspace ID unchanged","old generation fenced","new readiness evidence required"]},
    {"id":"M02_INVALID_CLIENT_RECONNECT_NEW_MATERIALIZATION","expected":"invalid","expected_code":"CLIENT_RECONNECT_NOT_MATERIALIZATION_GENERATION","schemas":["urn:ptah:schema:workspace:workspace-materialization:0.1.0"],"setup":"Shell/client reconnect increments runtime Materialization generation.","assertions":["only attachment/connection epoch changes"]},
    {"id":"M03_VALID_REMOTE_MATERIALIZATION","expected":"valid","schemas":["urn:ptah:schema:workspace:workspace-materialization:0.1.0"],"setup":"Workspace materializes through an approved remote Provider.","assertions":["remote_service_ref present","Node fields absent","Provider evidence retained"]},
    {"id":"M04_INVALID_MIXED_LOCAL_REMOTE","expected":"invalid","expected_code":"MATERIALIZATION_LOCALITY_AMBIGUOUS","schemas":["urn:ptah:schema:workspace:workspace-materialization:0.1.0"],"setup":"Materialization includes Node and remote-service locality simultaneously.","assertions":["reject mixed locality"]},
    {"id":"M05_INVALID_RUNNING_EQUALS_RECOVERED","expected":"invalid","expected_code":"RUNTIME_EXISTENCE_NOT_RECOVERY_PROOF","schemas":["urn:ptah:schema:workspace:workspace-materialization:0.1.0","urn:ptah:schema:workspace:recovery-verification:0.1.0"],"setup":"Materialization reaches running after restore and UI reports application recovered without postconditions.","assertions":["Recovery Verification required"]},
    {"id":"S01_VALID_DETACH_SESSION_CONTINUES","expected":"valid","schemas":["urn:ptah:schema:workspace:session:0.1.0","urn:ptah:schema:workspace:session-attachment:0.1.0"],"setup":"Last client Attachment detaches while terminal/browser/process Session continues.","assertions":["Attachment detached","Session active/idle allowed","Workspace unchanged"]},
    {"id":"S02_INVALID_PANEL_CLOSES_SESSION","expected":"invalid","expected_code":"PRESENTATION_STATE_NOT_SESSION_LIFECYCLE","schemas":["urn:ptah:schema:workspace:session:0.1.0"],"setup":"Closing a shell panel/layout is used as proof the runtime Session closed.","assertions":["explicit close Activity/read-back required"]},
    {"id":"S03_VALID_ACTIVE_NO_ATTACHMENTS","expected":"valid","schemas":["urn:ptah:schema:workspace:session:0.1.0"],"setup":"Persistent Session remains active with zero current Attachments.","assertions":["session persists according to Provider/policy"]},
    {"id":"S04_INVALID_STALE_ATTACHMENT_CONTROL","expected":"invalid","expected_code":"STALE_ATTACHMENT_EPOCH_OR_FENCE","schemas":["urn:ptah:schema:workspace:session-attachment:0.1.0"],"setup":"Old client epoch/fencing token sends input after reconnect/takeover.","assertions":["mutation rejected","observation may be retained"]},
    {"id":"J01_INVALID_MISSED_EVENT_REPLAYS_EFFECT","expected":"invalid","expected_code":"EVENT_REPLAY_NOT_SIDE_EFFECT_AUTHORITY","schemas":["urn:ptah:schema:workspace:workspace-journal-entry:0.1.0"],"setup":"Reconnect sees a missed command Event and automatically repeats a non-idempotent effect.","assertions":["reconcile Operation/Receipt/external truth first"]},
    {"id":"C01_INVALID_REQUIRED_COMPONENT_MISSING_COMPLETE","expected":"invalid","expected_code":"CHECKPOINT_COMPLETENESS_OVERCLAIM","schemas":["urn:ptah:schema:workspace:checkpoint-bundle:0.1.0","urn:ptah:schema:workspace:checkpoint-component:0.1.0"],"setup":"Bundle claims complete while a required component is failed, missing, unknown or excluded.","assertions":["overall completeness partial/mixed/failed/unknown"]},
    {"id":"C02_VALID_PARTIAL_CHECKPOINT","expected":"valid","schemas":["urn:ptah:schema:workspace:checkpoint-bundle:0.1.0"],"setup":"Partial bundle retains valid components, omissions and recovery limitations.","assertions":["partial evidence retained","no complete claim"]},
    {"id":"C03_INVALID_UNKNOWN_AS_APPLICATION_CONSISTENT","expected":"invalid","expected_code":"CHECKPOINT_CONSISTENCY_OVERCLAIM","schemas":["urn:ptah:schema:workspace:checkpoint-component:0.1.0"],"setup":"Unknown/crash consistency is relabeled application-consistent without quiesce/application proof.","assertions":["retain weaker/unknown consistency"]},
    {"id":"C04_INVALID_CREATED_EQUALS_COMPATIBLE","expected":"invalid","expected_code":"CHECKPOINT_PRODUCTION_NOT_COMPATIBILITY","schemas":["urn:ptah:schema:workspace:checkpoint-verification:0.1.0","urn:ptah:schema:workspace:restore-compatibility:0.1.0"],"setup":"Successful checkpoint file creation/integrity verification is used as restore compatibility.","assertions":["target-specific compatibility required"]},
    {"id":"C05_INVALID_RAW_SECRET_EXPORT","expected":"invalid","expected_code":"CHECKPOINT_SECRET_POLICY_VIOLATION","schemas":["urn:ptah:schema:workspace:checkpoint-component:0.1.0","urn:ptah:schema:workspace:workspace-export:0.1.0"],"setup":"Raw credentials/cookies/keys or encryption key are included without explicit encrypted policy.","assertions":["exclude/encrypt/reference/re-authorize","report omission/effect"]},
    {"id":"R01_INVALID_INCOMPATIBLE_TARGET_MUTATED","expected":"invalid","expected_code":"RESTORE_MUTATION_BEFORE_COMPATIBILITY","schemas":["urn:ptah:schema:workspace:restore-compatibility:0.1.0","urn:ptah:schema:workspace:restore-run:0.1.0"],"setup":"Restore starts applying state before non-expired compatibility/grants are accepted.","assertions":["reject before mutation"]},
    {"id":"R02_VALID_RUNTIME_RESTORED_APP_PARTIAL","expected":"valid","schemas":["urn:ptah:schema:workspace:restore-run:0.1.0","urn:ptah:schema:workspace:recovery-verification:0.1.0"],"setup":"Runtime exists but one application postcondition fails.","assertions":["Restore Run may be restored_runtime","Recovery outcome partially_recovered or not_recovered","limitations retained"]},
    {"id":"R03_INVALID_OLD_RECEIPTS_PROVE_RESTORE","expected":"invalid","expected_code":"STALE_GENERATION_RECOVERY_EVIDENCE","schemas":["urn:ptah:schema:workspace:restore-run:0.1.0","urn:ptah:schema:workspace:recovery-verification:0.1.0"],"setup":"Pre-checkpoint Attempts/Receipts are used to prove restored-generation processes/services.","assertions":["new-generation read-back/Receipts required"]},
    {"id":"R04_INVALID_UNCERTAIN_EFFECT_CLEARED","expected":"invalid","expected_code":"RESTORE_DOES_NOT_RESOLVE_EXTERNAL_EFFECT","schemas":["urn:ptah:schema:workspace:restore-run:0.1.0"],"setup":"Crash/restore marks uncertain payment/device/API mutation as not happened.","assertions":["retain uncertain Operation","read authoritative system/compensate/review"]},
    {"id":"R05_VALID_PARTIAL_RESTORE_AUTHORIZED","expected":"valid","schemas":["urn:ptah:schema:workspace:restore-request:0.1.0","urn:ptah:schema:workspace:restore-run:0.1.0"],"setup":"Compatibility is partial and request explicitly accepts reduced scope before mutation.","assertions":["failed/skipped components retained","no full recovery claim"]},
    {"id":"R06_INVALID_PARTIAL_USED_FOR_FULL","expected":"invalid","expected_code":"PARTIAL_COMPATIBILITY_SCOPE_NOT_ACCEPTED","schemas":["urn:ptah:schema:workspace:restore-request:0.1.0","urn:ptah:schema:workspace:restore-compatibility:0.1.0"],"setup":"Partially compatible target is used for requested full restore without scope reduction/approval.","assertions":["reject before mutation"]},
    {"id":"E01_VALID_EXPORT_WITH_OMISSIONS","expected":"valid","schemas":["urn:ptah:schema:workspace:workspace-export:0.1.0"],"setup":"Export omits nonportable/secrets/private records and states effect on recovery.","assertions":["allowlist/provenance/hashes retained","no hidden completeness claim"]},
    {"id":"I01_INVALID_SILENT_IDENTITY_MERGE","expected":"invalid","expected_code":"WORKSPACE_IMPORT_IDENTITY_DECISION_REQUIRED","schemas":["urn:ptah:schema:workspace:workspace-import-decision:0.1.0"],"setup":"Imported Workspace silently overwrites/merges an existing Workspace based on same name/path.","assertions":["explicit decision/authority/mapping required"]},
    {"id":"I02_VALID_NEW_IDS_WITH_PROVENANCE","expected":"valid","schemas":["urn:ptah:schema:workspace:workspace-import-decision:0.1.0"],"setup":"Cross-installation import creates new local Workspace identity and maps source IDs/provenance.","assertions":["Objects may retain digest identity where policy allows","memberships/credentials/bindings remapped"]},
    {"id":"X01_VALID_ONE_WORKSPACE_FAILURE_ISOLATED","expected":"valid","schemas":["urn:ptah:schema:workspace:workspace-materialization:0.1.0"],"setup":"One Workspace Materialization fails while another Workspace and Node remain available.","assertions":["failure scope isolated","Node not disconnected globally"]}
  ]
}