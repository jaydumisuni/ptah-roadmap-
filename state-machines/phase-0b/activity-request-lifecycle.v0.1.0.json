    {"name":"accepted","description":"A durable Activity was created and linked to this request.","terminal":true,"proof_dimension":"lifecycle","entry_requirements":["Accepted Activity reference and decision outcome exist."]},
    {"name":"rejected","description":"Request was denied or invalid and no Activity was created.","terminal":true,"proof_dimension":"lifecycle","entry_requirements":["Typed rejection outcome exists."]},
    {"name":"expired","description":"Request expired before acceptance.","terminal":true,"proof_dimension":"lifecycle","entry_requirements":["Expiry authority/time and outcome exist."]},
    {"name":"withdrawn","description":"Authorized requestor withdrew the request before acceptance.","terminal":true,"proof_dimension":"lifecycle","entry_requirements":["Withdrawal authority and outcome exist."]}
