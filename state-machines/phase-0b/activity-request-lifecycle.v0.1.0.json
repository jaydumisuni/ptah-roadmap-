    {"transition_name":"reject","from_states":["submitted","validating"],"to_state":"rejected","transition_class":"administrative","authority_classes":["ptah_control_plane","organization_policy"],"side_effecting":false,"required_preconditions":["Typed rejection outcome exists."],"required_evidence_kinds":[],"required_receipt_proof_levels":[]},
