    {"transition_name":"deprecate","from_states":["active","suspended"],"to_state":"deprecated","transition_class":"administrative","authority_classes":["workspace_owner","organization_policy"],"side_effecting":false,"required_preconditions":["Reason and replacement/migration guidance recorded."],"required_evidence_kinds":["receipt"],"required_receipt_proof_levels":["accepted"]},
