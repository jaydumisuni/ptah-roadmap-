{
  "state_machine_name": "device.protocol_operation.lifecycle",
  "state_machine_version": "0.1.0",
  "subject_entity_kinds": ["device.protocol_operation"],
  "states": [
    {"name": "prepared", "description": "Exact Device, Session, Interface, connection epoch, Provider generation, WP02 Operation and first Attempt are bound.", "terminal": false, "proof_dimension": "lifecycle", "entry_requirements": ["Current context and execution authority exist."]},
    {"name": "executing", "description": "One current physical protocol Attempt is executing.", "terminal": false, "proof_dimension": "lifecycle", "entry_requirements": ["New Attempt/nonce and current epoch/generation/fence exist."]},
    {"name": "acknowledged", "description": "The protocol/backend acknowledged completion but post-condition proof is not yet sufficient.", "terminal": false, "proof_dimension": "lifecycle", "entry_requirements": ["Correlated acknowledgement evidence exists."]},
    {"name": "verifying", "description": "Read-back, semantic post-condition or authoritative verification is executing.", "terminal": false, "proof_dimension": "lifecycle", "entry_requirements": ["Verification method and current context exist."]},
    {"name": "completed_verified", "description": "Required verification proved the bounded requested post-condition.", "terminal": true, "proof_dimension": "lifecycle", "entry_requirements": ["Verification record and Receipts exist."]},
    {"name": "completed_acknowledged", "description": "Only acknowledgement is proven under an explicit policy-bounded limitation.", "terminal": true, "proof_dimension": "lifecycle", "entry_requirements": ["Acknowledgement plus explicit authority/limitation exists."]},
    {"name": "failed", "description": "The operation failed with retained partial-effect and cleanup/recovery disposition.", "terminal": true, "proof_dimension": "lifecycle", "entry_requirements": ["Failure and reconciliation evidence exist."]},
    {"name": "cancelled", "description": "Cancellation completed with physical-effect reconciliation.", "terminal": true, "proof_dimension": "lifecycle", "entry_requirements": ["Cancellation and cleanup evidence exist."]},
    {"name": "uncertain", "description": "A non-idempotent effect may have occurred and must be reconciled before retry/resume.", "terminal": false, "proof_dimension": "lifecycle", "entry_requirements": ["Exact prior Attempt/epoch/generation and uncertainty evidence exist."]},
    {"name": "blocked", "description": "Current authority, capability, connection, Lease/fence, backup or policy blocks execution.", "terminal": false, "proof_dimension": "lifecycle", "entry_requirements": ["Structured blocker exists."]}
  ],
  "initial_states": ["prepared"],
  "transitions": [
    {"transition_name": "create", "from_states": [null], "to_state": "prepared", "transition_class": "normal", "authority_classes": ["ptah_control_plane"], "side_effecting": false, "required_preconditions": ["Exact Device/Session/Interface/connection/Provider context, WP02 Operation and new Attempt exist."], "required_evidence_kinds": ["receipt", "attempt", "capability_snapshot"], "required_receipt_proof_levels": ["accepted"]},
    {"transition_name": "execute", "from_states": ["prepared", "blocked"], "to_state": "executing", "transition_class": "normal", "authority_classes": ["ptah_control_plane", "provider"], "side_effecting": true, "required_preconditions": ["Current epoch/generation/Lease/fence and operation-specific authority remain valid."], "required_evidence_kinds": ["receipt", "attempt"], "required_receipt_proof_levels": ["dispatched"]},
    {"transition_name": "acknowledge", "from_states": ["executing"], "to_state": "acknowledged", "transition_class": "normal", "authority_classes": ["provider", "ptah_control_plane"], "side_effecting": false, "required_preconditions": ["Acknowledgement is correlated to exact Attempt/epoch/generation."], "required_evidence_kinds": ["receipt", "protocol_stage"], "required_receipt_proof_levels": ["operation_completed"]},
    {"transition_name": "begin_verify", "from_states": ["executing", "acknowledged", "uncertain"], "to_state": "verifying", "transition_class": "normal", "authority_classes": ["ptah_control_plane", "verifier"], "side_effecting": true, "required_preconditions": ["Verification method and readable/current target context exist."], "required_evidence_kinds": ["receipt", "verification_protocol"], "required_receipt_proof_levels": ["accepted"]},
    {"transition_name": "complete_verified", "from_states": ["verifying"], "to_state": "completed_verified", "transition_class": "normal", "authority_classes": ["ptah_control_plane", "verifier"], "side_effecting": false, "required_preconditions": ["Bounded post-condition verification passed."], "required_evidence_kinds": ["receipt", "verification"], "required_receipt_proof_levels": ["output_verified"]},
    {"transition_name": "complete_acknowledged", "from_states": ["acknowledged"], "to_state": "completed_acknowledged", "transition_class": "normal", "authority_classes": ["ptah_control_plane", "authorized_operator"], "side_effecting": false, "required_preconditions": ["Policy explicitly permits acknowledgement-only completion and limitations are retained."], "required_evidence_kinds": ["receipt", "authorization", "exception"], "required_receipt_proof_levels": ["operation_completed"]},
    {"transition_name": "mark_uncertain", "from_states": ["executing", "acknowledged", "verifying"], "to_state": "uncertain", "transition_class": "recovery", "authority_classes": ["provider", "ptah_control_plane", "verifier"], "side_effecting": false, "required_preconditions": ["Effect is unresolved after disconnect, timeout, Provider restart, fence expiry or contradictory evidence."], "required_evidence_kinds": ["receipt", "reconciliation"], "required_receipt_proof_levels": ["operation_completed"]},
    {"transition_name": "fail", "from_states": ["prepared", "executing", "acknowledged", "verifying", "uncertain", "blocked"], "to_state": "failed", "transition_class": "failure", "authority_classes": ["provider", "ptah_control_plane", "verifier"], "side_effecting": false, "required_preconditions": ["Failure and physical-effect/recovery disposition exist."], "required_evidence_kinds": ["receipt", "error", "reconciliation"], "required_receipt_proof_levels": ["operation_completed"]},
    {"transition_name": "cancel", "from_states": ["prepared", "executing", "acknowledged", "verifying", "uncertain", "blocked"], "to_state": "cancelled", "transition_class": "cancellation", "authority_classes": ["caller", "workspace_owner", "ptah_control_plane"], "side_effecting": true, "required_preconditions": ["Cancellation and physical-effect reconciliation/cleanup exist."], "required_evidence_kinds": ["receipt", "reconciliation"], "required_receipt_proof_levels": ["operation_completed"]},
    {"transition_name": "block", "from_states": ["prepared"], "to_state": "blocked", "transition_class": "normal", "authority_classes": ["provider", "ptah_control_plane"], "side_effecting": false, "required_preconditions": ["Structured current-context blocker exists."], "required_evidence_kinds": ["receipt"], "required_receipt_proof_levels": []}
  ],
  "unknown_state_policy": "reject",
  "migration_policy": {"state_mapping_required_for_breaking_change": true, "unmapped_state_behavior": "manual_review", "migration_definition_refs": []},
  "extensions": {}
}
