{
  "state_machine_name": "storage.location.lifecycle",
  "state_machine_version": "0.1.0",
  "subject_entity_kinds": ["storage.location"],
  "states": [
    {"name":"declared","description":"Location identity and target backend are recorded but bytes are not yet claimed available.","terminal":false,"proof_dimension":"lifecycle","entry_requirements":["Content and backend references exist."]},
    {"name":"materializing","description":"Bytes are being copied, uploaded, restored or finalized at the Location.","terminal":false,"proof_dimension":"lifecycle","entry_requirements":["Materialization Activity/Operation exists."]},
    {"name":"available","description":"Provider/location reports bytes available; verification remains an independent dimension.","terminal":false,"proof_dimension":"lifecycle","entry_requirements":["Availability observation and Receipt exist."]},
    {"name":"retiring","description":"Location is scheduled for removal or replacement but remains a retained record.","terminal":false,"proof_dimension":"lifecycle","entry_requirements":["Authorized deletion/retirement decision exists."]},
    {"name":"deleted","description":"Physical backend location was removed or confirmed absent after authorized deletion.","terminal":true,"proof_dimension":"lifecycle","entry_requirements":["Execution Receipt and post-delete observation exist."]}
  ],
  "initial_states": ["declared"],
  "transitions": [
    {"transition_name":"declare","from_states":[null],"to_state":"declared","transition_class":"normal","authority_classes":["ptah_control_plane","storage_provider"],"side_effecting":false,"required_preconditions":["Canonical Location ID, exact Content and backend scope exist."],"required_evidence_kinds":[],"required_receipt_proof_levels":[]},
    {"transition_name":"begin_materialization","from_states":["declared","available"],"to_state":"materializing","transition_class":"normal","authority_classes":["ptah_control_plane","storage_provider","facility"],"side_effecting":true,"required_preconditions":["Write/copy/restore authorization and destination scope are valid."],"required_evidence_kinds":["receipt"],"required_receipt_proof_levels":["dispatched"]},
    {"transition_name":"mark_available","from_states":["declared","materializing"],"to_state":"available","transition_class":"normal","authority_classes":["ptah_control_plane","storage_provider"],"side_effecting":false,"required_preconditions":["Provider/location availability was observed; verification is not inferred."],"required_evidence_kinds":["receipt","location_observation"],"required_receipt_proof_levels":["operation_completed"]},
    {"transition_name":"retire","from_states":["declared","available"],"to_state":"retiring","transition_class":"administrative","authority_classes":["workspace_owner","organization_policy","ptah_control_plane"],"side_effecting":false,"required_preconditions":["Authorized Storage Deletion Decision exists and required references remain protected."],"required_evidence_kinds":["receipt","deletion_decision"],"required_receipt_proof_levels":["operation_completed"]},
    {"transition_name":"confirm_deleted","from_states":["retiring"],"to_state":"deleted","transition_class":"administrative","authority_classes":["ptah_control_plane","storage_provider"],"side_effecting":true,"required_preconditions":["Physical deletion executed and post-delete observation confirms the Location is gone."],"required_evidence_kinds":["receipt","location_observation"],"required_receipt_proof_levels":["operation_completed"]},
    {"transition_name":"cancel_retirement","from_states":["retiring"],"to_state":"available","transition_class":"recovery","authority_classes":["workspace_owner","organization_policy","ptah_control_plane"],"side_effecting":false,"required_preconditions":["Deletion was not executed; continued availability is freshly observed."],"required_evidence_kinds":["receipt","location_observation"],"required_receipt_proof_levels":[]}
  ],
  "unknown_state_policy": "reject",
  "migration_policy": {"state_mapping_required_for_breaking_change":true,"unmapped_state_behavior":"manual_review","migration_definition_refs":[]},
  "extensions": {}
}