    {"transition_name":"mark_uncertain","from_states":["executing","acknowledged","verifying"],"to_state":"uncertain","transition_class":"recovery","authority_classes":["provider","ptah_control_plane","verifier"],"side_effecting":false,"required_preconditions":["Disconnect/provider restart/lease expiry leaves effect unresolved; blind retry is forbidden."],"required_evidence_kinds":["receipt","reconciliation"],"required_receipt_proof_levels":["operation_completed"]},
    {"transition_name":"block","from_states":["planned","preparing"],"to_state":"blocked","transition_class":"normal","authority_classes":["provider","ptah_control_plane"],"side_effecting":false,"required_preconditions":["Structured compatibility/authority/backup/connection blocker exists."],"required_evidence_kinds":["receipt"],"required_receipt_proof_levels":[]}
