{
  "state_machine_name":"firmware.operation.lifecycle","state_machine_version":"0.1.0","subject_entity_kinds":["firmware.operation"],
  "states":[
    {"name":"planned","description":"Operation has exact Plan, compatibility and authorization but has not started.","terminal":false,"proof_dimension":"lifecycle","entry_requirements":["Current Plan/authorization/backup/readback policy exist."]},
    {"name":"preparing","description":"Session/Lease/fence/epoch/generation/assets are being revalidated.","terminal":false,"proof_dimension":"lifecycle","entry_requirements":["Fresh context evidence exists."]},
    {"name":"executing","description":"Physical protocol Attempts are executing.","terminal":false,"proof_dimension":"lifecycle","entry_requirements":["New Attempt and current fence/epoch/generation exist."]},
    {"name":"acknowledged","description":"Backend/device acknowledged the operation but physical state is not verified.","terminal":false,"proof_dimension":"lifecycle","entry_requirements":["ACK/process result evidence exists."]},
    {"name":"verifying","description":"Read-back or authoritative verification is in progress.","terminal":false,"proof_dimension":"lifecycle","entry_requirements":["Verification protocol/Attempt exists."]},
    {"name":"completed_verified","description":"Required read-back/authoritative evidence matched expected state.","terminal":true,"proof_dimension":"lifecycle","entry_requirements":["Operation Verification decision is verified or verified_with_limitations."]},
    {"name":"completed_acknowledged","description":"Operation was acknowledged but verification was unavailable/not required under explicit authority.","terminal":true,"proof_dimension":"lifecycle","entry_requirements":["ACK plus explicit limitation/exception exists."]},
    {"name":"failed","description":"Operation terminally failed and partial physical state is recorded.","terminal":true,"proof_dimension":"lifecycle","entry_requirements":["Failure and recovery disposition exist."]},
    {"name":"cancelled","description":"Operation was cancelled before/after partial effect with retained reconciliation.","terminal":true,"proof_dimension":"lifecycle","entry_requirements":["Cancellation/reconciliation exists."]},
    {"name":"uncertain","description":"A non-idempotent physical effect may have occurred and remains unresolved.","terminal":false,"proof_dimension":"lifecycle","entry_requirements":["Exact old Attempt/epoch/generation and uncertainty evidence exist."]},
    {"name":"blocked","description":"Current compatibility/authority/backup/connection/provider condition prevents execution.","terminal":false,"proof_dimension":"lifecycle","entry_requirements":["Structured blocker exists."]}
