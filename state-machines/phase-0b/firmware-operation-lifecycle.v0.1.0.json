    {"transition_name":"acknowledge","from_states":["executing"],"to_state":"acknowledged","transition_class":"normal","authority_classes":["provider","ptah_control_plane"],"side_effecting":false,"required_preconditions":["Protocol/device/process ACK is correlated to exact Attempt/epoch/generation."],"required_evidence_kinds":["receipt","protocol_stage"],"required_receipt_proof_levels":["operation_completed"]},
    {"transition_name":"begin_verify","from_states":["acknowledged","executing","uncertain"],"to_state":"verifying","transition_class":"normal","authority_classes":["ptah_control_plane","verifier"],"side_effecting":true,"required_preconditions":["Verification protocol and current/readable target context exist."],"required_evidence_kinds":["receipt","verification_protocol"],"required_receipt_proof_levels":["accepted"]},
    {"transition_name":"complete_verified","from_states":["verifying"],"to_state":"completed_verified","transition_class":"normal","authority_classes":["ptah_control_plane","verifier"],"side_effecting":false,"required_preconditions":["Read-back/authoritative verification matches expected state."],"required_evidence_kinds":["receipt","operation_verification"],"required_receipt_proof_levels":["output_verified"]},
    {"transition_name":"complete_acknowledged","from_states":["acknowledged"],"to_state":"completed_acknowledged","transition_class":"normal","authority_classes":["ptah_control_plane","authorized_operator"],"side_effecting":false,"required_preconditions":["Read-back unavailable/not required only under explicit authority/exception and limitations."],"required_evidence_kinds":["receipt","authorization","exception"],"required_receipt_proof_levels":["operation_completed"]},
    {"transition_name":"fail","from_states":["planned","preparing","executing","acknowledged","verifying","blocked","uncertain"],"to_state":"failed","transition_class":"failure","authority_classes":["provider","ptah_control_plane","verifier"],"side_effecting":false,"required_preconditions":["Failure and partial physical state/recovery disposition exist."],"required_evidence_kinds":["receipt","error","reconciliation"],"required_receipt_proof_levels":["operation_completed"]},
