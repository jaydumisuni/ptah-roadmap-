    {"transition_name":"prepare","from_states":["planned","blocked","uncertain"],"to_state":"preparing","transition_class":"normal","authority_classes":["ptah_control_plane","provider"],"side_effecting":false,"required_preconditions":["Current Session/Lease/fence/epoch/generation/assets and backup are revalidated."],"required_evidence_kinds":["receipt","backup","capability_snapshot"],"required_receipt_proof_levels":["accepted"]},
