    {"transition_name":"resume","from_states":["suspended"],"to_state":"active","transition_class":"administrative","authority_classes":["workspace_owner","organization_policy","ptah_control_plane"],"side_effecting":false,"required_preconditions":["Membership and policy remain current."],"required_evidence_kinds":["receipt","review"],"required_receipt_proof_levels":["accepted"]},
