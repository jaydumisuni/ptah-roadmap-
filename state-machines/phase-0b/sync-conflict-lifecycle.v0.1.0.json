    {"name":"under_review","description":"Authorized review or merge analysis is in progress.","terminal":false,"proof_dimension":"lifecycle","entry_requirements":["Reviewer/Activity and policy are recorded."]},
    {"name":"resolved","description":"An accepted resolution decision and resulting revisions/mappings/tombstones are recorded.","terminal":true,"proof_dimension":"lifecycle","entry_requirements":["Resolution and follow-up verification exist."]},
    {"name":"postponed","description":"Conflict remains unresolved by explicit decision and blocks/limits affected scope.","terminal":false,"proof_dimension":"lifecycle","entry_requirements":["Postpone reason, expiry/review date and affected scope exist."]},
    {"name":"superseded","description":"Conflict is replaced by another conflict identity after split/reclassification while history remains.","terminal":true,"proof_dimension":"lifecycle","entry_requirements":["Successor relationship and evidence exist."]}
