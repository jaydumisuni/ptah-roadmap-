{
  "state_machine_name": "session.lifecycle",
  "state_machine_version": "0.1.0",
  "subject_entity_kinds": ["runtime.session"],
  "states": [
    {"name":"creating","description":"Session resources and subject binding are being established.","terminal":false,"proof_dimension":"lifecycle","entry_requirements":["Workspace, Provider, generations, owner and subtype are fixed."]},
    {"name":"active","description":"Session exists and may serve its declared subtype; attachments/control and health remain separate.","terminal":false,"proof_dimension":"lifecycle","entry_requirements":["Creation/start Receipt and subject references exist."]},
    {"name":"idle","description":"Session persists without current ordinary activity/control use.","terminal":false,"proof_dimension":"lifecycle","entry_requirements":["Provider supports persistence and idle policy is recorded."]},
    {"name":"suspending","description":"Subtype-supported suspension is in progress.","terminal":false,"proof_dimension":"lifecycle","entry_requirements":["Suspension Activity and limitations exist."]},
    {"name":"suspended","description":"Provider acknowledges subtype-supported suspension; checkpoint completeness remains separate.","terminal":false,"proof_dimension":"lifecycle","entry_requirements":["Suspension read-back and limitations are retained."]},
    {"name":"resuming","description":"Suspended/restored Session is re-establishing operation under current generation.","terminal":false,"proof_dimension":"lifecycle","entry_requirements":["Resume/restore authority is valid."]},
    {"name":"closing","description":"Session close and cleanup are in progress.","terminal":false,"proof_dimension":"lifecycle","entry_requirements":["Close Activity and child/attachment handling are recorded."]},
    {"name":"closed","description":"Session no longer serves its subtype; history remains.","terminal":true,"proof_dimension":"lifecycle","entry_requirements":["Close/read-back Receipts exist."]},
    {"name":"failed","description":"Exact-generation Session failure is durable and requires reconciliation or close/recovery.","terminal":false,"proof_dimension":"lifecycle","entry_requirements":["Failure evidence and uncertain work are retained."]},
    {"name":"quarantined","description":"Session is isolated from ordinary access pending policy/security review.","terminal":false,"proof_dimension":"lifecycle","entry_requirements":["Quarantine scope/fencing are recorded."]}
  ],
  "initial_states":["creating"],
  "transitions":[
    {"transition_name":"create","from_states":[null],"to_state":"creating","transition_class":"normal","authority_classes":["session_owner","workspace_owner","ptah_control_plane"],"side_effecting":true,"required_preconditions":["Workspace/Materialization/Provider context and subtype capability are valid."],"required_evidence_kinds":["receipt","dispatch_eligibility"],"required_receipt_proof_levels":["dispatched"]},
    {"transition_name":"activate","from_states":["creating","resuming"],"to_state":"active","transition_class":"normal","authority_classes":["provider","ptah_control_plane"],"side_effecting":false,"required_preconditions":["Session subject exists under current generation; attachment is not required."],"required_evidence_kinds":["receipt","session_subject"],"required_receipt_proof_levels":["process_started"]},
    {"transition_name":"idle","from_states":["active"],"to_state":"idle","transition_class":"normal","authority_classes":["provider","ptah_control_plane"],"side_effecting":false,"required_preconditions":["No conflicting active work/control and idle persistence is supported."],"required_evidence_kinds":["receipt"],"required_receipt_proof_levels":[]},
    {"transition_name":"wake","from_states":["idle"],"to_state":"active","transition_class":"normal","authority_classes":["session_owner","provider","ptah_control_plane"],"side_effecting":false,"required_preconditions":["Provider/generation and authority are current."],"required_evidence_kinds":["receipt"],"required_receipt_proof_levels":[]},
    {"transition_name":"begin_suspend","from_states":["active","idle"],"to_state":"suspending","transition_class":"administrative","authority_classes":["session_owner","workspace_owner","ptah_control_plane"],"side_effecting":true,"required_preconditions":["Subtype supports suspension and current work/control has explicit treatment."],"required_evidence_kinds":["receipt","capability_verification"],"required_receipt_proof_levels":["dispatched"]},
    {"transition_name":"mark_suspended","from_states":["suspending"],"to_state":"suspended","transition_class":"normal","authority_classes":["provider","ptah_control_plane"],"side_effecting":false,"required_preconditions":["Suspension/read-back and limitations are recorded."],"required_evidence_kinds":["receipt","read_back"],"required_receipt_proof_levels":["operation_completed"]},
    {"transition_name":"begin_resume","from_states":["suspended"],"to_state":"resuming","transition_class":"normal","authority_classes":["session_owner","workspace_owner","provider","ptah_control_plane"],"side_effecting":true,"required_preconditions":["Resume/restore authority and current provider/materialization generations are valid."],"required_evidence_kinds":["receipt"],"required_receipt_proof_levels":["dispatched"]},
    {"transition_name":"begin_close","from_states":["creating","active","idle","suspended","failed","quarantined"],"to_state":"closing","transition_class":"administrative","authority_classes":["session_owner","workspace_owner","provider","ptah_control_plane"],"side_effecting":true,"required_preconditions":["Attachments/control/child Sessions and uncertain work are handled."],"required_evidence_kinds":["receipt","reconciliation"],"required_receipt_proof_levels":["dispatched"]},
    {"transition_name":"mark_closed","from_states":["closing"],"to_state":"closed","transition_class":"normal","authority_classes":["provider","ptah_control_plane"],"side_effecting":false,"required_preconditions":["Session subject absence/closure and cleanup are verified."],"required_evidence_kinds":["receipt","read_back"],"required_receipt_proof_levels":["operation_completed"]},
    {"transition_name":"fail","from_states":["creating","active","idle","suspending","resuming","closing"],"to_state":"failed","transition_class":"failure","authority_classes":["provider","ptah_control_plane"],"side_effecting":false,"required_preconditions":["Exact generation/epoch failure and uncertain work are retained."],"required_evidence_kinds":["receipt","error","reconciliation"],"required_receipt_proof_levels":["operation_completed"]},
    {"transition_name":"quarantine","from_states":["creating","active","idle","suspended","failed"],"to_state":"quarantined","transition_class":"administrative","authority_classes":["organization_policy","ptah_control_plane"],"side_effecting":true,"required_preconditions":["Access/control/credential paths are fenced and reason recorded."],"required_evidence_kinds":["receipt","policy"],"required_receipt_proof_levels":["operation_completed"]}
  ],
  "unknown_state_policy":"reject",
  "migration_policy":{"state_mapping_required_for_breaking_change":true,"unmapped_state_behavior":"manual_review","migration_definition_refs":[]},
  "extensions":{}
}